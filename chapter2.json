ngular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter2.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter2.md","exports":[{"format":"md","filename":"chapter2.md","url":"tobydriscoll.net/SMiJ/build/chapter2-887683f9dcdab055ee4418536863318c.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Program 3","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"EyIoiUUUm7"}],"identifier":"program-3","label":"Program 3","html_id":"program-3","implicit":true,"key":"dAToaYkff7"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p3.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie\n\"p3 - band-limited interpolation\"\nfunction p3()\n    h = 1\n    xmax = 10\n    x = -xmax:h:xmax                     # computational grid\n    xx = -xmax-h/20:h/10:xmax+h/20       # plotting grid\n    sinc(t) = iszero(t) ? 1.0 : sinpi(t / h) / (π * t / h)\n    funs = [\n        x -> float(x==0),\n        x -> float(abs(x) <= 3),\n        x -> max(0, 1 - abs(x)/3)\n        ]\n    fig = Figure()\n    for (i, f) in enumerate(funs)\n        v = f.(x)\n        ax = Axis(fig[i, 1], yticks=[0, 1], limits=(-xmax, xmax, -0.5, 1.5))\n        scatter!(ax, x, v)\n        p = sum( v[j] * sinc.(xx .- x[j]) for j in eachindex(x) )\n        lines!(ax, xx, p)\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p3","identifier":"p3","filename":"p3","html_id":"p3","key":"QE19RZh69z"}],"key":"lYndcd9NRo"},{"type":"paragraph","position":{"start":{"line":17,"column":1},