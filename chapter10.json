thvariant=\"normal\">h</mi></mrow><mrow><mo fence=\"true\">(</mo><mn>1</mn><mi mathvariant=\"normal\">/</mi><mi>a</mi><mo fence=\"true\">)</mo></mrow></mrow></mfrac><mo separator=\"true\">,</mo></mrow><annotation encoding=\"application/x-tex\">\\tilde{y} = \\frac{\\mathrm{asinh} \\left(y/a\\right)}{\\mathrm{asinh} \\left(1/a\\right)},</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.8623em;vertical-align:-0.1944em;\"></span><span class=\"mord accent\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.6679em;\"><span style=\"top:-3em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span></span><span style=\"top:-3.35em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"accent-body\" style=\"left:-0.1944em;\"><span class=\"mord\">~</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.1944em;\"><span></span></span></span></span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:2.363em;vertical-align:-0.936em;\"></span><span class=\"mord\"><span class=\"mopen nulldelimiter\"></span><span class=\"mfrac\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:1.427em;\"><span style=\"top:-2.314em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord\"><span class=\"mord mathrm\">asinh</span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">(</span><span class=\"mord\">1/</span><span class=\"mord mathnormal\">a</span><span class=\"mclose delimcenter\" style=\"top:0em;\">)</span></span></span></span><span style=\"top:-3.23em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"frac-line\" style=\"border-bottom-width:0.04em;\"></span></span><span style=\"top:-3.677em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord\"><span class=\"mord mathrm\">asinh</span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">(</span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span><span class=\"mord\">/</span><span class=\"mord mathnormal\">a</span><span class=\"mclose delimcenter\" style=\"top:0em;\">)</span></span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.936em;\"><span></span></span></span></span></span><span class=\"mclose nulldelimiter\"></span></span><span class=\"mpunct\">,</span></span></span></span></span>","key":"FTAN32NbcA"},{"type":"paragraph","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"text","value":"where ","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"jSLliSwP72"},{"type":"inlineMath","value":"a","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>a</mi></mrow><annotation encoding=\"application/x-tex\">a</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\">a</span></span></span></span>","key":"yFKi4tpDsy"},{"type":"text","value":" is a parameter that controls the transition between linear and logarithmic behavior. The ","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"hZLy9FU6KG"},{"type":"inlineCode","value":"Makie.AsinhScale","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"pwQS4VbGGO"},{"type":"text","value":" constructor takes this parameter as an argument.","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"SRY4z41oTG"}],"key":"WFjypmlDq8"}],"icon":false,"class":"dropdown","key":"shwubXmkm0"},{"type":"heading","depth":2,"position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"Program 27","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"g3v1eY2A1Z"}],"identifier":"program-27","label":"Program 27","html_id":"program-27","implicit":true,"key":"l6bNtaWL07"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p27.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, FFTW\n\"\"\"\np27 - Solve KdV eq. u_t + u u_x + u_xxx = 0 on [-π, π] by\n        FFT with integrating factor v = exp(-ik³t) * û.\n\"\"\"\nfunction p27(N=256, tmax=0.006, Δt=0.4/N^2)\n    @assert iseven(N) \"Must choose an even value of N\"\n    # Set up grid and two-soliton initial data:\n    x = (2π / N) * (-N/2:N/2-1)\n    soliton(x, a) = 3a^2 * sech(0.5 * a * x)^2\n    u = @. soliton(x + 2, 25) + soliton(x + 1, 16)\n\n    # Set up time stepping:\n    tplot = tmax / 80\n    plotgap = round(Int, tplot / Δt)\n    Δt = tplot / plotgap\n    ntime = round(Int, tmax / Δt)\n\n    # Find integrating factor and solve PDE:\n    k = [0:N/2-1; 0]\n    ik³ = 1im * k .^ 3\n    g = -0.5im * Δt * k\n    E = exp.(Δt * ik³ / 2)\n    E² = E .^ 2\n    û = rfft(u)\n    udata = u\n    tdata = [0.0]\n    for n = 1:ntime\n        t = n * Δt\n        a = g .* rfft(irfft(û, N) .^ 2)\n        b = g .* rfft(irfft(E .* (û + a / 2), N) .^ 2)    # 4th-order...\n        c = g .* rfft(irfft(E .* û + b / 2, N) .^ 2)      # ...Runge–Kutta\n        d = g .* rfft(irfft(E² .* û + E .* c, N) .^ 2)\n        û = @. E² * û + (E² * a + 2 * E * (b + c) + d) / 6\n        if iszero(rem(n, plotgap))\n            u = irfft(û, N)\n            udata = [udata u]\n            tdata = [tdata; t]\n        end\n    end\n    return heatmap(x, tdata, udata; colormap=:Blues, interpolate=true,\n        axis=(xlabel=L\"x\", ylabel=L\"t\"))\nend","lang":"julia","showLineNumbers":true,"label":"p27","identifier":"p27","filename":"p27","html_id":"p27","key":"NocofkS1AF"}],"key":"xP6M5PBo92"},{"type":"heading","depth":3,"position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"children":[{"type":"text","value":"Output 27","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"OnyAOWuxke"}],"identifier":"output-27","label":"Output 27","html_id":"output-27","implicit":true,"key":"L1coiBKpaB"}],"key":"M4nXKfecw7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p27()","identifier":"output27-code","html_id":"output27-code","key":"pBpF3PmZ7E"},{"type":"outputs","id":"BkDLYwIOaap-AeermtXpr","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":5,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"07453f68b9583fb491a8243e362a92c2","path":"tobydriscoll.net/SMiJ/build/07453f68b9583fb491a8243e362a92c2.png"},"text/html":{"content_type":"text/html","hash":"08e5214118c0ea1d3da6483e7a1854a2","path":"tobydriscoll.net/SMiJ/build/08e5214118c0ea1d3da6483e7a1854a2.html"}}},"identifier":"output27-outputs-0","html_id":"output27-outputs-0","key":"WutjQJf7vw"}],"identifier":"output27-outputs","html_id":"output27-outputs","key":"Qht2NzMtAh"}],"label":"output27","identifier":"output27","html_id":"output27","key":"KB08jZ8yZ7"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"The heatmap in this case shows clearly the way the humps emerge from their interaction shifted from their original characteristic paths. That’s a nonlinear effect in KdV.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"cn0fDwKFAY"}],"key":"eJEqFuzhGs"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Real ","key":"KKr6m4lkdX"},{"type":"abbreviation","title":"fast Fourier transform","children":[{"type":"text","value":"FFT","key":"hukycCC0Xk"}],"key":"Umwh0kGspe"}],"key":"VJvKHGExM6"},{"type":"paragraph","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"children":[{"type":"text","value":"Because we use ","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"ngOtulXc75"},{"type":"inlineCode","value":"rfft","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"YOuz8mom6z"},{"type":"text","value":" and ","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"u9vEnGzR6c"},{"type":"inlineCode","value":"irfft","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"dVhnzbVhBZ"},{"type":"text","value":" for the Fourier transforms, we never have to explictly take the real part of the results, and we enjoy a factor of 2 speedup over a generic ","key":"dORvXx9ap9"},{"type":"abbreviation","title":"fast Fourier transform","children":[{"type":"text","value":"FFT","key":"WDdC16O0OY"}],"key":"SxLnGnkSeU"},{"type":"text","value":".","key":"APFKXGPtrv"}],"key":"SX79KX70BM"}],"icon":false,"class":"dropdown","key":"NFmGVNQI0y"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Interpolated heatmap","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"DqYE5UX540"}],"key":"wpXR1ZQVIj"},{"type":"paragraph","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"text","value":"I used ","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"rcvWOlldsD"},{"type":"inlineCode","value":"interpolate=true","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"Q2p85AJtin"},{"type":"text","value":" in the ","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"ZsR8MwNaxA"},{"type":"inlineCode","value":"heatmap","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"gQjNX1P0Ua"},{"type":"text","value":" call to get a smoother-looking plot. I guess that’s a bit hypocritical given my earlier stances on keeping spectral accuracy, but interpolating faithfully to 4th order in time is not easy here.","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"yDErcYmU77"}],"key":"fNgqOyfZaL"},{"type":"paragraph","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Simple fixed-time-step implementations of methods for ","key":"kA1jhSkwYg"},{"type":"abbreviation","title":"initial-value problem","children":[{"type":"text","value":"IVP","key":"FsoL3PMhLi"}],"key":"i0lyuzMwsR"},{"type":"text","value":"s are great to learn from, but they should not be used when solving challenging problems. Julia has the best collection of ","key":"JLbXJa0h7o"},{"type":"abbreviation","title":"initial-value problem","children":[{"type":"text","value":"IVP","key":"R5z8AWDY1g"}],"key":"y9RAJJfwvj"},{"type":"text","value":" solvers in the world, in the ","key":"pj0LB4KA4w"},{"type":"link","url":"https://docs.sciml.ai/DiffEqDocs/stable/","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"DifferentialEquations","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"Af3DhtwoAO"}],"urlSource":"https://docs.sciml.ai/DiffEqDocs/stable/","key":"ITFboYLD0q"},{"type":"text","value":" package. Most of its sovlers automatically provide adaptive step size and interpolation in time. The package even offers ","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"T5IoYuzO5P"},{"type":"link","url":"https://docs.sciml.ai/DiffEqDocs/stable/solvers/ode_solve/#exp_RK","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"exponential Runge–Kutta methods","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"D3IefKL28U"}],"urlSource":"https://docs.sciml.ai/DiffEqDocs/stable/solvers/ode_solve/#exp_RK","key":"Bkp9ECTUdn"},{"type":"text","value":" ready to use.","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"CmEgAYW3DI"}],"key":"RdpafCD0Tb"}],"icon":false,"class":"dropdown","key":"qB4pCGRXlk"},{"type":"heading","depth":2,"position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"children":[{"type":"text","value":"Program 27-anim","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"OloSGecGLH"}],"identifier":"program-27-anim","label":"Program 27-anim","html_id":"program-27-anim","implicit":true,"key":"wemojoaRVm"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p27anim.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, Printf, FFTW\n\"\"\"\np27anim - Solve KdV eq. u_t + u u_x + u_xxx = 0 on [-π, π] by\n        FFT with integrating factor v = exp(-ik³t) * û.\n\"\"\"\nfunction p27anim(N=256, tmax=0.006, Δt=0.4/N^2)\n    @assert iseven(N) \"Must choose an even value of N\"\n    # Set up grid and two-soliton initial data:\n    x = (2π / N) * (-N/2:N/2-1)\n    soliton(x, a) = 3a^2 * sech(0.5 * a * x)^2\n    u = @. soliton(x + 2, 25) + soliton(x + 1, 16)\n\n    # Set up time stepping:\n    tplot = tmax / 150\n    plotgap = ceil(Int, tplot / Δt)\n    Δt = tplot / plotgap\n    ntime = round(Int, tmax / Δt)\n\n    # Find integrating factor and solve PDE:\n    k = [0:N/2-1; 0]\n    ik³ = 1im * k .^ 3\n    g = -0.5im * Δt * k\n    E = exp.(Δt * ik³ / 2)\n    E² = E .^ 2\n    time = Observable(0.0)\n    title = @lift @sprintf(\"t = %0.2e\", $time)\n    û = rfft(u)\n    u = Observable(u)\n    fig = lines(x, u;\n        axis=(; xlabel=L\"x\", xticks=MultiplesTicks(5, π, \"π\"), title))\n    anim = record(fig, \"p27anim-$N-$(1000tmax).mp4\"; framerate=30) do io\n        recordframe!(io)\n        for n in 1:ntime\n            a = g .* rfft(irfft(û, N) .^ 2)\n            b = g .* rfft(irfft(E .* (û + a / 2), N) .^ 2)    # 4th-order...\n            c = g .* rfft(irfft(E .* û + b / 2, N) .^ 2)      # ...Runge–Kutta\n            d = g .* rfft(irfft(E² .* û + E .* c, N) .^ 2)\n            û = @. E² * û + (E² * a + 2 * E * (b + c) + d) / 6\n            if iszero(rem(n, plotgap))\n                u[] = irfft(û, N)\n                time[] = n * Δt\n                recordframe!(io)\n            end\n        end\n    end\n    return anim\nend\n","lang":"julia","showLineNumbers":true,"label":"p27anim","identifier":"p27anim","filename":"p27anim","html_id":"p27anim","key":"QBocMu9USI"}],"key":"RpnGgK1F8M"},{"type":"heading","depth":3,"position":{"start":{"line":129,"column":1},"end":{"line":129,"column":1}},"children":[{"type":"text","value":"Output 27-anim","position":{"start":{"line":129,"column":1},"end":{"line":129,"column":1}},"key":"HNkLDBZEfz"}],"identifier":"output-27-anim","label":"Output 27-anim","html_id":"output-27-anim","implicit":true,"key":"S3KdNs8IpB"}],"key":"VKFUC1eeds"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p27anim()","identifier":"output27anim-code","visibility":"show","html_id":"output27anim-code","key":"pzejX1GDgk"},{"type":"outputs","id":"4GBGxYK_RNSQhCOPbtzn-","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","data":{"text/plain":"\"p27anim-256-6.0.mp4\""},"metadata":{},"execution_count":6},"identifier":"outp