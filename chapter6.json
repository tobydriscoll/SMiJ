{"version":3,"kind":"Notebook","sha256":"fdde63e3ec5df5442dfe5ac06d27fe8891e4686919ff272a45f82a1c5e80904c","slug":"chapter6","location":"/chapter6.md","dependencies":[],"frontmatter":{"title":"Chapter 6","subtitle":"Function cheb, Programs p11, p12","kernelspec":{"name":"julia-1.11","display_name":"Julia 1","language":"julia"},"github":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl","numbering":{"title":{"enabled":false},"code":{"enabled":false},"equation":{"enabled":false},"heading_1":{"enabled":false},"heading_2":{"enabled":false},"heading_3":{"enabled":false},"heading_4":{"enabled":false},"heading_5":{"enabled":false},"heading_6":{"enabled":false}},"math":{"\\float":{"macro":"\\mathbb{F}"},"\\real":{"macro":"\\mathbb{R}"},"\\complex":{"macro":"\\mathbb{C}"},"\\nat":{"macro":"\\mathbb{N}"},"\\integer":{"macro":"\\mathbb{Z}"},"\\rmn":{"macro":"\\mathbb{R}^{#1 \\times #2}"},"\\dd":{"macro":"\\frac{d #1}{d #2}"},"\\ddd":{"macro":"\\frac{d^2 #1}{d #2^2}"},"\\pp":{"macro":"\\frac{\\partial #1}{\\partial #2}"},"\\ppp":{"macro":"\\frac{\\partial^2 #1}{\\partial #2^2}"},"\\ppdd":{"macro":"\\frac{\\partial^2 #1}{\\partial #2 \\partial #3}"},"\\abs":{"macro":"\\left\\lvert #1 \\right\\rvert"},"\\norm":{"macro":"\\left\\lVert #1 \\right\\rVert"},"\\twonorm":{"macro":"\\norm{#1}_2"},"\\onenorm":{"macro":"\\norm{#1}_1"},"\\infnorm":{"macro":"\\norm{#1}_\\infty"},"\\anynorm":{"macro":"\\norm{#1}_#2"},"\\innerprod":{"macro":"\\langle #1,#2 \\rangle"},"\\pr":{"macro":"^{(#1)}"},"\\kron":{"macro":"#1 \\otimes #2"},"\\macheps":{"macro":"\\epsilon_\\text{mach}"},"\\fl":{"macro":"\\operatorname{fl}"},"\\diag":{"macro":"\\operatorname{diag}"},"\\ign":{"macro":"\\operatorname{sign}"},"\\Re":{"macro":"\\operatorname{Re}"},"\\Im":{"macro":"\\operatorname{Im}"},"\\ee":{"macro":"\\times 10^"},"\\floor":{"macro":"\\lfloor#1\\rfloor"}},"abbreviations":{"SMiM":"Spectral Methods in MATLAB","IVP":"initial-value problem","BVP":"boundary-value problem","TPBVP":"two-point boundary-value problem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter6.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter6.md","exports":[{"format":"md","filename":"chapter6.md","url":"/build/chapter6-1f101ca5d5bbd75fb24e6b8357c1876f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"cheb","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"Trw3mfT4Fv"}],"label":"chapter6","identifier":"chapter6","html_id":"chapter6","key":"u7I1iaJie6"},{"type":"include","file":"SpectralMethodsTrefethen/src/cheb.jl","literal":true,"html_id":"cheb","children":[{"type":"code","value":"\"\"\"\n    cheb(N)\nChebyshev differentiation matrix and grid.\n\"\"\"\nfunction cheb(N)\n    (N == 0) && return zeros(1, 1), [1.0]\n    x = [sinpi(k / 2N) for k in N:-2:-N]\n    c = [2; ones(N-1); 2]\n    @. c[2:2:end] = -c[2:2:end]\n    # compute the off-diagonal entries\n    D = [c[i] / (c[j] * (x[i] - x[j] + (i==j))) for i in eachindex(x), j in eachindex(x)]\n    # negative sum trick to get the diagonal entries\n    for i in eachindex(x)\n        D[i, i] = -sum(D[i, j] for j in eachindex(x) if j != i)\n    end\n    return D, x\nend\n","lang":"julia","showLineNumbers":true,"label":"cheb","identifier":"cheb","filename":"cheb","html_id":"cheb","key":"NHSJeKVsVf"}],"key":"IfwtEBeM9O"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"This is the first formal function in ","position":{"start":{"line":21,"column":1},"end":{"