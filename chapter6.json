},{"type":"text","value":". Short-circuiting means that if the first clause is false, then the second clause isn’t evaluated, because the entire expression must be false anyway. This is a nice feature to avoid pesky runtime errors in conditional expressions, as in","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"nWZDNyM6aO"}],"key":"vZQqscnJcv"},{"type":"code","lang":"julia","value":"if (length(x) >= 5) && (x[5] > 0)","position":{"start":{"line":35,"column":1},"end":{"line":37,"column":1}},"key":"xrzOmNjbRE"},{"type":"paragraph","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Here, though, it’s being used as a compact—some would say cryptic—alternative to the construction","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"j8DOU9cYbC"}],"key":"JUkgKHHBAH"},{"type":"code","lang":"julia","value":"if N == 0\n    return zeros(1, 1), [1.0]\nend","position":{"start":{"line":41,"column":1},"end":{"line":45,"column":1}},"key":"vhWlY74OkD"},{"type":"paragraph","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"A similar trick works with the OR operator ","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"kddJSURfP7"},{"type":"inlineCode","value":"||","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"AQ0VQHyAKZ"},{"type":"text","value":", which skips the second clause if the first is true. For example,","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"zK8XpsT73T"}],"key":"B0SodGFeh8"},{"type":"code","lang":"julia","value":"(max_error < tol) || @warn(\"Error exceeds tolerance.\")","position":{"start":{"line":49,"column":1},"end":{"line":51,"column":1}},"key":"PDDTpgt7Cv"}],"icon":false,"class":"dropdown","key":"xS38hslXMG"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Minimizing allocations","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"Uzhio5PLR7"}],"key":"MBf00uw8SK"},{"type":"paragraph","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"children":[{"type":"text","value":"There is a subtle difference between the given line 9,","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"key":"uyFQIOEzn2"}],"key":"YAqb8zZXTF"},{"type":"code","lang":"julia","value":"@. c[2:2:end] = -c[2:2:end]","position":{"start":{"line":59,"column":1},"end":{"line":61,"column":1}},"key":"hvErXHmzhY"},{"type":"paragraph","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"and the functionally equivalent line","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"ysy9w97y5k"}],"key":"WZaWs4L6aI"},{"type":"code","lang":"julia","value":"c[2:2:end] = -c[2:2:end]","position":{"start":{"line":65,"column":1},"end":{"line":67,"column":1}},"key":"Es22dxe5rj"},{"type":"paragraph","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"children":[{"type":"text","value":"The former version implies a copy of the vector from the right-hand side to the left-hand side. But the second version implies an assignment to a subarray of the vector on the left-hand side, thus requiring extra allocation of temporary storage for the subarray.","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"key":"Xx0H8q4rqm"}],"key":"gemqtBnGCu"},{"type":"paragraph","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"In fact, even the first version requires allocations (for the right-hand side) we don’t need. The fastest version of this line is a loop:","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"key":"gIYbmeLSTV"}],"key":"MJEGx5D5oo"},{"type":"code","lang":"julia","value":"for j in 2:2:length(c)\n    c[j] = -c[j]\nend","position":{"start":{"line":73,"column":1},"end":{"line":77,"column":1}},"key":"VfmtwjeLvr"},{"type":"paragraph","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"children":[{"type":"text","value":"Coders in MATLAB and Python are (rightly) taught to avoid loops, but in Julia, loops carry no intrinsic penalty—sometimes, quite the opposite.","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"K4vO7DCnTY"}],"key":"uesPYjnFxy"}],"icon":false,"class":"dropdown","key":"pbjG7kyIJi"},{"type":"heading","depth":2,"position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"Program 11","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"i1FioSC86C"}],"identifier":"program-11","label":"Program 11","html_id":"program-11","implicit":true,"key":"Iz0YYakQq9"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p11.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings\nusing SpectralMethodsTrefethen, ForwardDiff\n\"p11 - Chebyshev differentation of a smooth function\"\nfunction p11()\n    f(x) = exp(x) * sin(5x)\n    df_dx(x) = ForwardDiff.derivative(f, x)\n    fig = Figure()\n    for (i, N) in enumerate([10, 20])\n        D, x = cheb(N)\n        v = f.(x)\n\n        Axis(fig[i, 1]; title=latexstring(\"\\$u(x),\\\\,  N=$N\\$\"))\n        scatter!(fig[i, 1], x, v)\n        lines!(fig[i, 1], -1..1, f)\n\n        error = D * v - df_dx.(x)\n        Axis(fig[i, 2]; title=latexstring(\"error in \\$u'(x),\\\\,  N=$N\\$\"))\n        scatterlines!(fig[i, 2], x, error; linestyle=:dot)\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p11","identifier":"p11","filename":"p11","html_id":"p11","key":"NSPlxD0fGm"}],"key":"bxmoXQYrdF"},{"type":"heading","depth":3,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Output 11","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"EFyFNTebqh"}],"identifier":"output-11","label":"Output 11","html_id":"output-11","implicit":true,"key":"EV9FyFWs7S"}],"key":"fttyI1CQvz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"using SpectralMethodsTrefethen\np11()","identifier":"output11-code","html_id":"output11-code","key":"ECJdarnbpv"},{"type":"outputs","id":"fei8Dfvw1w15ElxwWZiuw","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"9db7fa4f742b5729ca74dcc86156a72f","path":"/build/9db7fa4f742b5729ca74dcc86156a72f.png"},"text/html":{"content_type":"text/html","hash":"cbd327ec701f5339e29f162a2a46c583","path":"/build/cbd327ec701f5339e29f162a2a46c583.html"}}},"identifier":"output11-outputs-0","html_id":"output11-outputs-0","key":"N0MinGQAW3"}],"identifier":"output11-outputs","html_id":"output11-outputs","key":"ChbsL019fK"}],"label":"output11","identifier":"output11","html_id":"output11","key":"KutYno99Vu"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"children":[{"type":"text","value":"There are no new Julia tricks here, but there is a stylistic change from the original Output 11. In both versions, the solid curves on the left column show the given exact function. In the right column, the original program connected the dots with solid lines again, but only as a visual guide—the lines don’t mean anything, really. I’ve had students get confused on that point, so here I’ve used a dotted line to connect the points, just to hint that something is different.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"qkSqZIlNSp"}],"key":"bMAnIMLaTC"},{"type":"heading","depth":2,"position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"children":[{"type":"text","value":"Program 12","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"AtDRz2bJ1F"}],"identifier":"program-12","label":"Program 12","html_id":"program-12","implicit":true,"key":"FaSr6iPQXj"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p12.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, SpectralMethodsTrefethen\n\"p12 - accuracy of Chebyshev spectral differentiation (compare p7)\"\nfunction p12(Nmax = 50)\n    # Compute derivatives for various values of N:\n    # 3rd deriv in BV, C^∞; analytic, polynomial\n    funs = [x -> abs(x)^3            x -> exp(-x^(-2));\n            x -> 1 / (1 + x^2)       x -> x^10]\n    E = zeros(2, 2, Nmax)\n    for N in 1:Nmax\n        D, x = cheb(N)\n        for (i, f) in pairs(funs)\n            v = f.(x)\n            df_dx = ForwardDiff.derivative.(f, x)\n            E[i, N] = maximum(abs, D * v - df_dx)\n        end\n    end\n\n    # Plot results:\n    fig = Figure()\n    titles = [L\"|x|^3\"  L\"\\exp(-x^2)\"; L\"1/(1+x^2)\"  L\"x^{10}\"]\n    ax = [Axis(fig[i, j]; title=titles[i, j], yscale=log10) for i in 1:2, j in 1:2]\n    linkaxes!(ax...)\n    for (i, ax) in pairs(ax)\n        scatterlines!(ax, 1:Nmax, E[i, :])\n    end\n    ax[1, 1].ylabel = ax[2, 1].ylabel = \"error\"\n    ax[2, 1].xlabel = ax[2, 2].xlabel = L\"N\"\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p12","identifier":"p12","filename":"p12","html_id":"p12","key":"DxcLs2QAXk"}],"key":"ERkY3iZE2L"},{"type":"heading","depth":3,"position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"children":[{"type":"text","value":"Output 12","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"mqc3by4xQo"}],"identifier":"output-12","label":"Output 12","html_id":"output-12","implicit":true,"key":"vEPwQP35Jp"}],"key":"hQApON60Qy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p12()","identifier":"output12-code","html_id":"output12-code","key":"AHke6MR4IK"},{"type":"outputs","id":"2aKkFBoOOm0loS05BJVM_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":2,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"939daf9b3b1f36c3c1d36f639d81de09","path":"/build/939daf9b3b1f36c3c1d36f639d81de09.png"},"text/html":{"content_type":"text/html","hash":"d206bcf1777e1b35d9ece6635181ff74","path":"/build/d206bcf1777e1b35d9ece6635181ff74.html"}}},"identifier":"output12-outputs-0","html_id":"output12-outputs-0","key":"vTLVgaYauG"}],"identifier":"output12-outputs","html_id":"output12-outputs","key":"CYhqFHKWY9"}],"label":"output12","identifier":"output12","html_id":"output12","key":"FAfx0p0sSu"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"You’re meant to compare these plots to ","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"DBFcC24g2N"},{"type":"crossReference","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Output 7","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"Fgetzi8owp"}],"identifier":"output7","label":"output7","kind":"block:notebook-code","template":"Notebook-code","resolved":true,"html_id":"output7","remote":true,"url":"/chapter4","dataUrl":"/chapter4.json","key":"iGTKnwwNPW"},{"type":"text","value":" for periodic functions.","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"tukKbqKNbc"}],"key":"nbShbq2LfP"}],"key":"Slq5CtByPi"}],"key":"RCil2hIRGr"},"references":{"cite":{"order":["Weideman_2000"],"data":{"Weideman_2000":{"label":"Weideman_2000","enumerator":"1","doi":"10.1145/365723.365727","html":"Weideman, J. A., & Reddy, S. C. (2000). A MATLAB different