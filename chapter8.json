{"version":3,"kind":"Notebook","sha256":"5c7ab5e7cc1ac8693b0e8ee76b3f431f6e851e708be366f262a8c878f4d6e741","slug":"chapter8","location":"/chapter8.md","dependencies":[],"frontmatter":{"title":"Chapter 8","subtitle":"Function chebfft, Programs p18, p19, p20","kernelspec":{"name":"julia-1.11","display_name":"Julia 1","language":"julia"},"github":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl","numbering":{"title":{"enabled":false},"code":{"enabled":false},"equation":{"enabled":false},"heading_1":{"enabled":false},"heading_2":{"enabled":false},"heading_3":{"enabled":false},"heading_4":{"enabled":false},"heading_5":{"enabled":false},"heading_6":{"enabled":false}},"math":{"\\float":{"macro":"\\mathbb{F}"},"\\real":{"macro":"\\mathbb{R}"},"\\complex":{"macro":"\\mathbb{C}"},"\\nat":{"macro":"\\mathbb{N}"},"\\integer":{"macro":"\\mathbb{Z}"},"\\rmn":{"macro":"\\mathbb{R}^{#1 \\times #2}"},"\\dd":{"macro":"\\frac{d #1}{d #2}"},"\\ddd":{"macro":"\\frac{d^2 #1}{d #2^2}"},"\\pp":{"macro":"\\frac{\\partial #1}{\\partial #2}"},"\\ppp":{"macro":"\\frac{\\partial^2 #1}{\\partial #2^2}"},"\\ppdd":{"macro":"\\frac{\\partial^2 #1}{\\partial #2 \\partial #3}"},"\\abs":{"macro":"\\left\\lvert #1 \\right\\rvert"},"\\norm":{"macro":"\\left\\lVert #1 \\right\\rVert"},"\\twonorm":{"macro":"\\norm{#1}_2"},"\\onenorm":{"macro":"\\norm{#1}_1"},"\\infnorm":{"macro":"\\norm{#1}_\\infty"},"\\anynorm":{"macro":"\\norm{#1}_#2"},"\\innerprod":{"macro":"\\langle #1,#2 \\rangle"},"\\pr":{"macro":"^{(#1)}"},"\\kron":{"macro":"#1 \\otimes #2"},"\\macheps":{"macro":"\\epsilon_\\text{mach}"},"\\fl":{"macro":"\\operatorname{fl}"},"\\diag":{"macro":"\\operatorname{diag}"},"\\ign":{"macro":"\\operatorname{sign}"},"\\Re":{"macro":"\\operatorname{Re}"},"\\Im":{"macro":"\\operatorname{Im}"},"\\ee":{"macro":"\\times 10^"},"\\floor":{"macro":"\\lfloor#1\\rfloor"}},"abbreviations":{"SMiM":"Spectral Methods in MATLAB","IVP":"initial-value problem","BVP":"boundary-value problem","TPBVP":"two-point boundary-value problem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter8.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter8.md","exports":[{"format":"md","filename":"chapter8.md","url":"tobydriscoll.net/SMiJ/build/chapter8-4dc5a95a30dd1813ce938920fb910eb9.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"chebfft","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"im4QDwUTSF"}],"identifier":"chebfft","label":"chebfft","html_id":"chebfft","implicit":true,"key":"jUHv16I2q7"},{"type":"include","file":"SpectralMethodsTrefethen/src/chebfft.jl","literal":true,"html_id":"chebfft-1","children":[{"type":"code","value":"DCT(v) = FFTW.r2r(v, FFTW.REDFT00)\nDST(v) = FFTW.r2r(v, FFTW.RODFT00)\n\n\"\"\"\n    chebfft(v)\nDifferentiate values given at Chebyshev points via the FFT.\n\"\"\"\nfunction chebfft(v)\n    N = length(v) - 1\n    (N == 0) && return zero(v)\n    x = [sinpi(k / 2N) for k in N:-2:-N]\n    v̂ = DCT(v)\n    w = similar(v)\n    if N > 1\n        ξ = 1:N-1\n        q = DST(-ξ .* v̂[2:N])\n        w[2:N] = @. -q / (2N * sqrt(1 - x[2:N]^2))\n    end\n    w[1] = N/2 * v̂[N+1] + sum(n^2 * v̂[n+1] for n in 0:N-1) / N\n    w[N+1] = (-1)^(N+1) * N/2 * v̂[N+1] +\n        sum((-1)^(n+1) * n^2 * v̂[n+1] for n in 0:N-1) / N\n    return w\nend","lang":"julia","showLineNumbers":true,"label":"chebfft","identifier":"chebfft","filename":"chebfft","html_id":"chebfft","key":"nmd23xTbz8"}],"key":"viesCsjtgK"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"I have structured my implementation of ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"TWU3Ij04Gy"},{"type":"inlineCode","value":"chebfft","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"MITWm5S2RB"},{"type":"text","value":" to take advantage of the factor of 4 efficiency mentioned in the text. The ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"e4x1VsZQ3H"},{"type":"inlineCode","value":"FFTW","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"WNPj75cl5e"},{"type":"text","value":" package gives us access to the discrete cosine and sine transforms, which I give the more convenient names ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"uUJqF8gfKS"},{"type":"inlineCode","value":"DCT","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"HO5NA63EoS"},{"type":"text","value":" and ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"PT8ajhh0JE"},{"type":"inlineCode","value":"DST","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"hsSweeqXxu"},{"type":"text","value":". The DCT implicitly assumes even symmetry, which avoids the need to create an extended vector of the data. Once we differentiate cosines to get sines, we have an odd function, so the DST is the natural choice for the inverse transform; it expects us to omit the values we know to be zero at the endpoints. Everything else operates much like it does in the MATLAB code.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"naRoansvDj"}],"key":"tulgoRA65g"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"inlineCode","value":"similar","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"niktDJHgGC"}],"key":"KeT3YTFj3S"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"e3xqOD1fen"},{"type":"inlineCode","value":"similar","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"UuSH3rs7oB"},{"type":"text","value":" function creates an uninitialized array with the same size and element type as the given array. We have to be careful here not to specify either a real or complex array, since we want the result to have the same type as the input. We could get a valid result using ","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"dtYd61jyTb"},{"type":"inlineCode","value":"w = copy(v)","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"KcaYb6ltDP"},{"type":"text","value":", but that causes an unnecessary copy of the data.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"ChkweMibk4"}],"key":"J40WIx2VAj"}],"icon":false,"class":"dropdown","key":"u3qTMiKqNA"},{"type":"heading","depth":2,"position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"Program 18","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"Z6tN1XGjag"}],"identifier":"program-18","label":"Program 18","html_id":"program-18","implicit":true,"key":"j3nAGn5H9X"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p18.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, SpectralMethodsTrefethen, ForwardDiff\n\"p18 - Chebyshev differentiation via FFT (compare p11)\"\nfunction p18()\n    f(x) = exp(x) * sin(5x)\n    fprime(x) = ForwardDiff.derivative(f, x)\n    fig = Figure()\n    for (i, N) in enumerate([10, 20])\n        _, x = cheb(N)\n        v = f.(x)\n\n        Axis(fig[i, 1]; title=latexstring(\"\\$u(x),\\\\,  N=$N\\$\"))\n        scatter!(fig[i, 1], x, v)\n        lines!(fig[i, 1], -1..1, f)\n\n        error = chebfft(v) - fprime.(x)\n        Axis(fig[i, 2]; title=latexstring(\"error in \\$u'(x),\\\\,  N=$N\\$\"))\n        scatter!(fig[i, 2], x, error)\n        lines!(fig[i, 2], -1..1, chebinterp(error))\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p18","identifier":"p18","filename":"p18","html_id":"p18","key":"XkrCnMiXAt"}],"key":"qby1bBW9Ix"},{"type":"heading","depth":3,"position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"Output 18","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"X3nUwAism5"}],"identifier":"output-18","label":"Output 18","html_id":"output-18","implicit":true,"key":"nA4dDsW7Dv"}],"key":"ZwkofwUfK0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"using SpectralMethodsTrefethen\np18()","identifier":"output18-code","html_id":"output18-code","key":"ayYcyChjH3"},{"type":"outputs","id":"ReTwfAhegTq1tZrCf8HY5","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"3f2f69dbbf4f4c4620cc12d6d8783e62","path":"tobydriscoll.net/SMiJ/build/3f2f69dbbf4f4c4620cc12d6d8783e62.png"},"text/html":{"content_type":"text/html","hash":"469f2842d25a8f7dd565ecaa9b0cc68b","path":"tobydriscoll.net/SMiJ/build/469f2842d25a8f7dd565ecaa9b0cc68b.html"}}},"identifier":"output18-outputs-0","html_id":"output18-outputs-0","key":"WqjuHZJX42"}],"identifier":"output18-outputs","html_id":"output18-outputs","key":"vCuJ2BK1hz"}],"label":"output18","identifier":"output18","html_id":"output18","key":"Emzc8FUN35"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"I made a change compared to ","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"LSsTIaxlZM"},{"type":"crossReference","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Output 11","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"XraM3DfRg4"}],"identifier":"output11","label":"output11","kind":"block:notebook-code","template":"Notebook-code","resolved":true,"html_id":"output11","remote":true,"url":"/chapter6","dataUrl":"/chapter6.json","key":"EPYhtdGNkx"},{"type":"text","value":". For the right-hand column, I show the discrete error as markers as usual, but instead of connected them with straight lines, I use ","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"yXvZTPfB0q"},{"type":"inlineCode","value":"chebinterp","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"TzC8KnoohZ"},{"type":"text","value":" to show the error as a continuous function. I like this here because it dispels the appearance that the discrete errors are local extrema.","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"qwZAxRjwgY"}],"key":"WmzstfApO1"},{"type":"heading","depth":2,"position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Program 19","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"H1Q3GOwXA6"}],"identifier":"program-19","label":"Program 19","html_id":"program-19","implicit":true,"key":"jEuqyjgM56"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p19.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, FFTW, SpectralMethodsTrefethen\n\"p19 - 2nd-order wave eq. on Chebyshev grid (compare p6)\"\nfunction p19(N=80, tmax=4, Δt=8/N^2)\n    _, x = cheb(N)\n    v = @. exp(-200x^2)\n    vold = @. exp(-200 * (x - Δt)^2)\n\n    # Time-stepping by leap frog formula:\n    tplot = 0.025\n    plotgap = round(Int, tplot / Δt)\n    Δt = tplot / plotgap\n    ntime = round(Int, tmax / Δt)\n    data = hcat(v, zeros(N+1, ntime))\n    t = Δt * (0:ntime)\n    for i = 1:ntime\n        w = chebfft(chebfft(v))\n        w[[1, N+1]] .= 0\n        vnew = 2v - vold + Δt^2 * w\n        data[:, i+1] = vnew\n        vold, v = v, vnew\n    end\n\n    # Plot results:\n    return heatmap(x, t[1:plotgap:end], data[:, 1:plotgap:end];\n        colormap=:redsblues, colorrange=(-1, 1),\n        axis=(xlabel=L\"x\", ylabel=L\"t\"))\nend","lang":"julia","showLineNumbers":true,"label":"p19","identifier":"p19","filename":"p19","html_id":"p19","key":"p3OminD6AJ"}],"key":"PmFQw4LQux"},{"type":"heading","depth":3,"position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"Output 19","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"acMulFLM5x"}],"identifier":"output-19","label":"Output 19","html_id":"output-19","implicit":true,"key":"ZOj0p7W8qT"}],"key":"WBzth8wyLS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p19()","identifier":"output19-code","html_id":"output19-code","key":"zDOLmG5NRZ"},{"type":"outputs","id":"b9DiHbkcRQJj0EWBDcxsY","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":2,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"9be7f9c81ce8abcedbb47e81267dc474","path":"tobydriscoll.net/SMiJ/build/9be7f9c81ce8abcedbb47e81267dc474.png"},"text/html":{"content_type":"text/html","hash":"c25ee113aa154650d6ff21bdcf5ebf23","path":"tobydriscoll.net/SMiJ/build/c25ee113aa154650d6ff21bdcf5ebf23.html"}}},"identifier":"output19-outputs-0","html_id":"output19-outputs-0","key":"PwjUXpUo8L"}],"identifier":"output19-outputs","html_id":"output19-outputs","key":"kM1zGl8Nzm"}],"label":"output19","identifier":"output19","html_id":"output19","key":"Ki6czc9B4E"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"The reds–blues colormap makes it perfectly clear that the bump inverts whenever it reflects from a boundary. The animation is fun as well:","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"MWw619p0Re"}],"key":"PfN08Xv1aN"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p19anim.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, Printf, LaTeXStrings\nusing FFTW, SpectralMethodsTrefethen\n\"p19anim - 2nd-order wave eq. on Chebyshev grid (compare p6)\"\nfunction p19anim(N=80, tmax=4, Δt=8/N^2)\n    _, x = cheb(N)\n\n    tplot = 0.005\n    plotgap = round(Int, tplot / Δt)\n    Δt = tplot / plotgap\n    ntime = round(Int, tmax / Δt)\n\n    # Time-stepping by leap frog formula:\n    time = Observable(0.0)\n    title = @lift latexstring(@sprintf(\"\\$t = %0.2f\\$\", $time))\n    v = Observable(@. exp(-200x^2))\n    vold = @. exp(-200 * (x - Δt)^2)\n    fig = lines(x, v; axis=(; xlabel=L\"x\", title, limits=(-1, 1, -1, 1)))\n    anim = record(fig, \"p19anim-$N-$tmax.mp4\"; framerate=60) do io\n        recordframe!(io)\n        for n in 1:ntime\n            w = chebfft(chebfft(v[]))\n            w[[1, N+1]] .= 0\n            vnew = 2v[] - vold + Δt^2 * w\n            vold = v[]\n            v[] = vnew\n            time[] = n * Δt\n            iszero(mod(n, plotgap)) && recordframe!(io)\n        end\n      end\n    return anim\nend","lang":"julia","showLineNumbers":true,"label":"p19anim","identifier":"p19anim","filename":"p19anim","html_id":"p19anim","key":"M7zT6SYc8V"}],"key":"cpkjUJ4FOq"}],"key":"qarDeqaFdz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p19anim()","visibility":"show","key":"GtlotBR0He"},{"type":"outputs","id":"uk0A7yEpu__EaMu94NwPB","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","data":{"text/plain":"\"p19anim-80-4.mp4\""},"metadata":{},"execution_count":3},"key":"ndp47mT1TU"}],"visibility":"remove","key":"l4mhxf1WyH"}],"data":{"tags":[]},"visibility":"show","key":"kSBGVvYMfC"},{"type":"block","children":[{"type":"image","url":"tobydriscoll.net/SMiJ/build/p19anim-80-4-e391ca1eb645fab86a5bb724c9a3625b.mp4","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"label":"output19anim","identifier":"output19anim","html_id":"output19anim","key":"HwTmn5QQXa","urlSource":"p19anim-80-4.mp4"},{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Compare this solution to ","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"FJt3XXbnbs"},{"type":"crossReference","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Output 6","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"szdkl1Q5cq"}],"identifier":"output6anim","label":"output6anim","kind":"image","template":"Image","resolved":true,"html_id":"output6anim","remote":true,"url":"/chapter3","dataUrl":"/chapter3.json","key":"eNRTtU5iVw"},{"type":"text","value":", where we had a variable speed on a periodic domain.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"zIWIWzywfm"}],"key":"fw9Xn0jevG"},{"type":"paragraph","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"Your eye tells you that this solution is underresolved, but spectral methods are meant to run at coarse resolutions. To smooth out the animation, it would be easy to use the Chebyshev interpolant on a finer plotting grid.","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"Zn4bq5aSMD"}],"key":"liRErgHk1S"},{"type":"heading","depth":2,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Program 20-anim","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"AlQvIoyLhJ"}],"identifier":"program-20-anim","label":"Program 20-anim","html_id":"program-20-anim","implicit":true,"key":"xfIhFoEaFX"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p20anim.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, Printf\nusing FFTW, SpectralMethodsTrefethen\n\"p20anim - 2nd-order wave eq. in 2D via FFT (compare p19)\"\nfunction p20anim(N=24, tmax=1, Δt=6/N^2)\n    # Grid and initial data:\n    x = y = cheb(N)[2]\n    DCT(v) = FFTW.r2r(v, FFTW.REDFT00)\n    DST(v) = FFTW.r2r(v, FFTW.RODFT00)\n    function fftderiv2(v)\n        N = length(v) - 1\n        x = [cospi(k / N) for k in 0:N]\n        v̂ = DCT(v)\n        dQ_dθ = DST(-(1:N-1) .* v̂[2:N]) / 2N    # omits n=0, n=N\n        d²Q_dθ² = DCT(-(0:N).^2 .* v̂) / 2N\n        w₂ = zero(v)    # return zero at boundaries\n        # Chain rule for θ -> x:\n        for n in 2:N\n            s² = 1 / (1 - x[n]^2)\n            s = sqrt(s²)\n            w₂[n] = s² * (d²Q_dθ²[n] - x[n] * dQ_dθ[n-1] * s)\n        end\n        return w₂\n    end\n\n    V = [exp(-40 * ((x - 0.4)^2 + y^2)) for x in x, y in y]\n    Vold = copy(V)\n    Vxx = similar(V)\n    Vyy = similar(V)\n\n    tplot = 1 / 60\n    plotgap = round(Int, tplot / Δt)\n    Δt = tplot / plotgap\n    ntime = round(Int, tmax / Δt)\n\n    # Time-stepping by leap frog formula:\n    time = Observable(0.0)\n    title = @lift latexstring(@sprintf(\"\\$t = %0.2f\\$\", $time))\n    V = Observable(V)\n    xx = yy = range(-1, 1, 151)\n    VV = @lift interp2dgrid($V, chebinterp, chebinterp, xx, yy)\n    fig = Figure()\n    ax = Axis(fig[1, 1]; xlabel=L\"x\", ylabel=L\"y\", aspect=DataAspect(),\n                limits = (-1, 1, -1, 1), title)\n    heatmap!(ax, xx, yy, VV; colorrange=(-0.75, 0.75), colormap=:redsblues)\n    anim = record(fig, \"p20anim-$N-$tmax.mp4\"; framerate=30) do io\n        recordframe!(io)\n        for n in 1:ntime\n            Vxx = mapslices(fftderiv2, V[]; dims=[1])\n            Vyy = mapslices(fftderiv2, V[]; dims=[2])\n            Vnew = 2V[] - Vold + Δt^2 * (Vxx + Vyy)\n            time[] = n * Δt\n            Vold, V[] = V[], Vnew\n            iszero(mod(n, plotgap)) && recordframe!(io)\n        end\n    end\n    return anim\nend","lang":"julia","showLineNumbers":true,"label":"p20anim","identifier":"p20anim","filename":"p20anim","html_id":"p20anim","key":"vjoxltbCmb"}],"key":"YaTN4S1lun"},{"type":"heading","depth":3,"position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"Output 20-anim","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"RnsUIdI7vr"}],"identifier":"output-20-anim","label":"Output 20-anim","html_id":"output-20-anim","implicit":true,"key":"Skn48ZPwjs"}],"key":"InGGfAMHCx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p20anim(32, 3)","visibility":"show","key":"HETRjZekwk"},{"type":"outputs","id":"26wOxXngycQHyfTdibqMK","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","data":{"text/plain":"\"p20anim-32-3.mp4\""},"metadata":{},"execution_count":4},"key":"cdgycCmnA5"}],"visibility":"remove","key":"K6HujmhbWr"}],"data":{"tags":[]},"visibility":"show","key":"RlT3feE4NM"},{"type":"block","children":[{"type":"image","url":"tobydriscoll.net/SMiJ/build/p20anim-32-3-492ed21f8ccb125f3fae822c80d17be4.mp4","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"label":"output20anim","identifier":"output20anim","html_id":"output20anim","key":"zYJ3HXtUza","urlSource":"p20anim-32-3.mp4"},{"type":"paragraph","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"children":[{"type":"text","value":"I went straight to the animation this time. I chose to break out the ","key":"NAz8LUT5kB"},{"type":"abbreviation","title":"fast Fourier transform","children":[{"type":"text","value":"FFT","key":"wqJIRFtOLy"}],"key":"bHxAEQGEVE"},{"type":"text","value":" differentiation into its own function, ","key":"KRZnfH6U5V"},{"type":"inlineCode","value":"fftderiv2","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"ZdDRKgeVJw"},{"type":"text","value":". It’s patterned after the ","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"qIiFs8083M"},{"type":"inlineCode","value":"chebfft","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"hiwYr2iSB7"},{"type":"text","value":" function, but it returns the second derivative—except at the boundaries, where it returns zero. This ensures that the solution remains constant on the boundary during the time stepping. Note that the second derivative in ","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"NPaPGAorC3"},{"type":"inlineMath","value":"\\theta","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>θ</mi></mrow><annotation encoding=\"application/x-tex\">\\theta</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">θ</span></span></span></span>","key":"da2Hox3466"},{"type":"text","value":" is a cosine series again, so the DCT is needed to invert its transform.","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"cXcBWn2Ooe"}],"key":"rcynFDyWsQ"},{"type":"paragraph","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"This 1-D function is then mapped to slices along each dimension in order to get the second partials needed for the wave equation. Technically, a true 2-D ","key":"DAbvbdKyEv"},{"type":"abbreviation","title":"fast Fourier transform","children":[{"type":"text","value":"FFT","key":"sIstMRo2q9"}],"key":"K1eBqZDcsp"},{"type":"text","value":" from ","key":"ppjtGBfesB"},{"type":"inlineCode","value":"FFTW","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"l5sX1xSENE"},{"type":"text","value":" would be more efficient than repeated applications of 1-D ","key":"hakvm2MLO8"},{"type":"abbreviation","title":"fast Fourier transform","children":[{"type":"text","value":"FFT","key":"kPo38LTaBM"}],"key":"TadqztpUcK"},{"type":"text","value":"s. But the efficiency difference is unimportant unless ","key":"m90B22OB0b"},{"type":"inlineMath","value":"N","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>N</mi></mrow><annotation encoding=\"application/x-tex\">N</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.10903em;\">N</span></span></span></span>","key":"I4asZados0"},{"type":"text","value":" is quite large, and the extra complication to the code is not worthwhile here.","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"if4wymHxWG"}],"key":"ovbFFnKWhV"},{"type":"admonition","kind":"caution","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Caution","key":"eoOViKt5ij"}],"key":"amSO21NEZ9"},{"type":"paragraph","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"It’s tempting to distill lines 28–29 into the multiple assignment","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"sRvZhBlFBE"}],"key":"BFGVlmch6Q"},{"type":"code","lang":"julia","value":"Vxx = Vyy = similar(V)","position":{"start":{"line":110,"column":1},"end":{"line":112,"column":1}},"key":"vR8RkziBMa"},{"type":"paragraph","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"However, this would make both variables aliases of the same array! We need two separate arrays here.","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"Vp1iRlQICA"}],"key":"G3YATIWH1h"}],"key":"yjewNl9SIK"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Color range","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"YQYZMvpOQD"}],"key":"U8dDQFpjXK"},{"type":"paragraph","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"children":[{"type":"text","value":"The color range for the heatmap is set to ","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"NJMfsGOfLZ"},{"type":"inlineMath","value":"[-0.75, 0.75].","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">[</mo><mo>−</mo><mn>0.75</mn><mo separator=\"true\">,</mo><mn>0.75</mn><mo stretchy=\"false\">]</mo><mi mathvariant=\"normal\">.</mi></mrow><annotation encoding=\"application/x-tex\">[-0.75, 0.75].</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">[</span><span class=\"mord\">−</span><span class=\"mord\">0.75</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">0.75</span><span class=\"mclose\">]</span><span class=\"mord\">.</span></span></span></span>","key":"LfOTsXyqbU"},{"type":"text","value":" Hence, values greater or less than these values map to the extreme colors in the colormap. While this makes the plot of the initial condition less visually informative, the amplitude of the solution diminishes quickly, and we get more color during most of the animation than we would by using the range ","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"lyJqolu9OQ"},{"type":"inlineMath","value":"[-1, 1]","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">[</mo><mo>−</mo><mn>1</mn><mo separator=\"true\">,</mo><mn>1</mn><mo stretchy=\"false\">]</mo></mrow><annotation encoding=\"application/x-tex\">[-1, 1]</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">[</span><span class=\"mord\">−</span><span class=\"mord\">1</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">1</span><span class=\"mclose\">]</span></span></span></span>","key":"R8QUuaBBoy"},{"type":"text","value":".","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"lm4FMrCmPH"}],"key":"MZSmox4hFw"}],"icon":false,"class":"dropdown","key":"cUhnFo7pTA"}],"key":"lKz02Kjz0V"}],"key":"RGHlkU3VDx"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Chapter 7","url":"/chapter7","group":"Spectral Methods in Julia"},"next":{"title":"Chapter 9","url":"/chapter9","group":"Spectral Methods in Julia"}}},"domain":"http://localhost:3003"}