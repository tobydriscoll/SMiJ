{"version":3,"kind":"Notebook","sha256":"eb8d6982aa6f470d6e4a4da79a1a8a50200395b8f0addc38a45ca0776dfafcb0","slug":"chapter4","location":"/chapter4.md","dependencies":[],"frontmatter":{"title":"Chapter 4","subtitle":"Programs p7, p8","kernelspec":{"name":"julia-1.11","display_name":"Julia 1","language":"julia"},"github":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl","numbering":{"title":{"enabled":false},"code":{"enabled":false},"equation":{"enabled":false},"heading_1":{"enabled":false},"heading_2":{"enabled":false},"heading_3":{"enabled":false},"heading_4":{"enabled":false},"heading_5":{"enabled":false},"heading_6":{"enabled":false}},"math":{"\\float":{"macro":"\\mathbb{F}"},"\\real":{"macro":"\\mathbb{R}"},"\\complex":{"macro":"\\mathbb{C}"},"\\nat":{"macro":"\\mathbb{N}"},"\\integer":{"macro":"\\mathbb{Z}"},"\\rmn":{"macro":"\\mathbb{R}^{#1 \\times #2}"},"\\dd":{"macro":"\\frac{d #1}{d #2}"},"\\ddd":{"macro":"\\frac{d^2 #1}{d #2^2}"},"\\pp":{"macro":"\\frac{\\partial #1}{\\partial #2}"},"\\ppp":{"macro":"\\frac{\\partial^2 #1}{\\partial #2^2}"},"\\ppdd":{"macro":"\\frac{\\partial^2 #1}{\\partial #2 \\partial #3}"},"\\abs":{"macro":"\\left\\lvert #1 \\right\\rvert"},"\\norm":{"macro":"\\left\\lVert #1 \\right\\rVert"},"\\twonorm":{"macro":"\\norm{#1}_2"},"\\onenorm":{"macro":"\\norm{#1}_1"},"\\infnorm":{"macro":"\\norm{#1}_\\infty"},"\\anynorm":{"macro":"\\norm{#1}_#2"},"\\innerprod":{"macro":"\\langle #1,#2 \\rangle"},"\\pr":{"macro":"^{(#1)}"},"\\kron":{"macro":"#1 \\otimes #2"},"\\macheps":{"macro":"\\epsilon_\\text{mach}"},"\\fl":{"macro":"\\operatorname{fl}"},"\\diag":{"macro":"\\operatorname{diag}"},"\\ign":{"macro":"\\operatorname{sign}"},"\\Re":{"macro":"\\operatorname{Re}"},"\\Im":{"macro":"\\operatorname{Im}"},"\\ee":{"macro":"\\times 10^"},"\\floor":{"macro":"\\lfloor#1\\rfloor"}},"abbreviations":{"SMiM":"Spectral Methods in MATLAB","IVP":"initial-value problem","BVP":"boundary-value problem","TPBVP":"two-point boundary-value problem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter4.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter4.md","exports":[{"format":"md","filename":"chapter4.md","url":"https://tobydriscoll.net/SMiJ/build/chapter4-ad79f23debb90764b661363239d09d18.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 7","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"T8DOk3UzGH"}],"identifier":"program-7","label":"Program 7","html_id":"program-7","implicit":true,"key":"RsoJqQCPqm"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p7.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings\nusing ToeplitzMatrices, ForwardDiff\n\"p7 - accuracy of periodic spectral differentiation\"\nfunction p7(Nmax = 50)\n    # Compute derivatives for various values of N:\n    N = 6:2:Nmax\n    funs = [x -> abs(sin(x))^3            x -> exp(-sin(x / 2)^(-2));\n            x -> 1 / (1 + sin(x / 2)^2)   x -> sin(10x)]\n    E = zeros(2, 2, length(N))\n    for (k, N) in enumerate(N)\n        h = 2π / N\n        x = h * (1:N)\n        col = [0.5 * (-1)^j * cot(j * h / 2) for j in 1:N-1]\n        D = Toeplitz([0; col], [0; reverse(col)])\n        for (i, f) in pairs(funs)\n            v = f.(x)\n            vprime = ForwardDiff.derivative.(f, x)\n            E[i, k] = maximum(abs, D * v - vprime)\n        end\n    end\n\n    # Plot results:\n    titles = [L\"|\\sin(x)|^3\" L\"\\exp(-\\sin^{-2}(x/2))\"; L\"1/(1+\\sin^2(x/2))\" L\"\\sin(10x)\"]\n    fig = Figure()\n    ax = [Axis(fig[i, j]; title=titles[i, j], yscale=log10) for i in 1:2, j in 1:2]\n    linkaxes!(ax...)\n    for (i, ax) in pairs(ax)\n        scatterlines!(ax, N, E[i, :])\n    end\n    ax[1, 1].ylabel = ax[2, 1].ylabel = \"error\"\n    ax[2, 1].xlabel = ax[2, 2].xlabel = L\"N\"\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p7","identifier":"p7","filename":"p7","html_id":"p7","key":"KIvJqi5Wnf"}],"key":"Er3TATUcUk"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"One of my favorite perks in Makie is the ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"th8kfXXGDU"},{"type":"inlineCode","value":"linkaxes!","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"OvhUvhxKuB"},{"type":"text","value":" function, which tells Makie to give all the linked axes the same limits. That’s used to great effect in the output (like in the original), where it’s instantly clear how much slower convergence is in the top two cases:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"ZDKpflLxTj"}],"key":"VItRIbk6zy"},{"type":"heading","depth":3,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Output 7","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"iRtKpQjh53"}],"identifier":"output-7","label":"Output 7","html_id":"output-7","implicit":true,"key":"cESP6LG3ry"}],"key":"VnEGPvVoVp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"using SpectralMethodsTrefethen\nfig = p7()","identifier":"output7-code","html_id":"output7-code","key":"d1SyIT95oH"},{"type":"outputs","id":"yExnaGSLSGaLd77RYhpK-","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"image/png":{"conten