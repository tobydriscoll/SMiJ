umn":1},"end":{"line":56,"column":1}},"key":"DXnh8Bqbfx"}],"identifier":"clencurt","label":"clencurt","html_id":"clencurt","implicit":true,"key":"Ucptb5Islo"},{"type":"include","file":"SpectralMethodsTrefethen/src/clencurt.jl","literal":true,"html_id":"clencurt-1","children":[{"type":"code","value":"\"\"\"\n    clencurt(N)\nNodes and weights for Clenshaw–Curtis quadrature.\n\"\"\"\nfunction clencurt(N, T::Type{<:AbstractFloat}=Float64)\n    q = [T(i) / N for i in 0:N]\n    x = cospi.(q)\n    w = zeros(T, N+1)\n    v = ones(T, N-1)\n    if iseven(N)\n        w[1] = w[N+1] = one(T) / (N^2 - 1)\n        for k in 1:div(N, 2)-1\n            @. v -= 2cospi(2k * q[2:N]) / (4k^2 - 1)\n        end\n        @. v -= cospi(N * q[2:N]) / (N^2 - 1)\n    else\n        w[1] = w[N+1] = one(T) / N^2\n        for k in 1:div(N-1, 2)\n            @. v -= 2cospi(2k * q[2:N]) / (4k^2 - 1)\n        end\n    end\n    w[2:N] = 2v / N\n    return x, w\nend","lang":"julia","showLineNumbers":true,"label":"clencurt","identifier":"clencurt","filename":"clencurt","html_id":"clencurt","key":"L34PlavShC"}],"key":"NuVDWwLLRV"},{"type":"paragraph","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"I’ve had some fun here by extending ","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"bNezz68fbk"},{"type":"inlineCode","value":"clencurt","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"XgLIXLbHFo"},{"type":"text","value":" to work with floating-point types other than double precision, which is called ","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"QkUXAfE7iv"},{"type":"inlineCode","value":"Float64","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"j3HtoaAnat"},{"type":"text","value":" in Julia. Base Julia has some less-precise types, such as ","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"ps9a8LHswa"},{"type":"inlineCode","value":"Float32","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"GvQvHYBQIp"},{"type":"text","value":", and some more-precise types, such as ","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"YVXgjHqaY0"},{"type":"inlineCode","value":"BigFloat","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"oWWb4jTxRo"},{"type":"text","value":", which is a variable-precision type. There are also add-on packages such as ","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"CkipUple7g"},{"type":"inlineCode","value":"DoubleFloats","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"wFnyXUJhTd"},{"type":"text","value":" and ","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"Gi6WWp71Vy"},{"type":"inlineCode","value":"MultiFloats","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"hELfGssQAW"},{"type":"text","value":" that can give higher fixed precision with greater speed than ","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"DMUjbEh88V"},{"type":"inlineCode","value":"BigFloat","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"twyo5xK6J4"},{"type":"text","value":".","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"pJEmqWo9aQ"}],"key":"fcMvUNPvi9"},{"type":"paragraph","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"children":[{"type":"text","value":"All that Clenshaw–Curtis requires is basic arithmetic and the cosine function, so it is easy to generalize. One has to be mindful that some operations, such as the ratio of integers, default to ","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"i3jUdH1gT8"},{"type":"inlineCode","value":"Float64","position":{"start":{"line":68,"column":1},"end":{"line":68,