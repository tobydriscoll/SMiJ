line":87,"column":1},"end":{"line":87,"column":1}},"key":"l0hAQXVTwo"}],"identifier":"gauss","label":"gauss","html_id":"gauss","implicit":true,"key":"irMd3QUkfp"},{"type":"include","file":"SpectralMethodsTrefethen/src/gauss.jl","literal":true,"html_id":"gauss-1","children":[{"type":"code","value":"\"\"\"\n    gauss(N)\nNodes and weights for Gauss quadrature.\n\"\"\"\nfunction gauss(N)\n    β = [0.5 / sqrt(1 - 1 / 4i^2) for i in 1:N-1]\n    T = SymTridiagonal(zeros(N), β)\n    x, V = eigen(T)\n    return x, 2V[1, :] .^ 2\nend","lang":"julia","showLineNumbers":true,"label":"gauss","identifier":"gauss","filename":"gauss","html_id":"gauss","key":"vsdWOBUurw"}],"key":"C3kqpDe1mn"},{"type":"paragraph","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"children":[{"type":"text","value":"If we want to extend ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"rrE3z9zQxh"},{"type":"inlineCode","value":"gauss","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"TKf9zQbqcw"},{"type":"text","value":" to work in higher precision, we need an eigensolver that works with that type. Those exist, but the relative cost is much higher than for Clenshaw–Curtis.","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"d5juOuXu84"}],"key":"W76n7G3Zl3"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"inlineCode","value":"SymTridiagonal","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"gXqSiAxNcg"}],"key":"AFSj5eGWAM"},{"type":"paragraph","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"gRA16nPPl4"},{"type":"inlineCode","value":"SymTridiagonal","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"WqbWCc64Yf"},{"type":"text","value":" type is a special type for symmetric tridiagonal matrices. It is used here because the matrix in the Golub–Welsch algorithm has those properties, and the eigensolver for that case is a lot more efficient than the general-purpose one.","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"cJTAZc6f5n"}],"key":"mJokrnxoEk"}],"icon":false,"class":"dropdown","key":"bdl35t8wjn"},{"type":"heading","depth":3,"position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"Output 30c","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"xhnnHgb7YH"}],"identifier":"output-30c","label":"Output 30c","html_id":"output-30c","implicit":true,"key":"RztVbbvGQm"}],"key":"HCNfKmVDm1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p30(gauss)","identifier":"output30c-code","html_id":"output30c-code","key":"YQ8mdoZqaX"},{"type":"outputs","id":"rUuT86zzU_Tb6sTZsr7zU","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"7093f795c56feffdf9c1d8a0c99d5b1c","path":"https://tobydriscoll.net/SMiJ/build/7093f795c56feffdf9c1d8a0c99d5b1c.png"},"text/html":{"content_type":"text/html","hash":"b92d17861caccbe65495b550f53bd7a1","path":"https://tobydriscoll.net/SMiJ/build/b92d17861caccbe65495b550f53bd7a1.html"}}},"identifier":"output30c-outputs-0","html_id":"output30c-outputs-0","key":"GwghcMVP4Z"}],"identifier":"output30c-outputs","html_id":"output30c-outputs","key":"edVTiC2Iri"}],"label":"output30c","identifier":"output30c","html_id":"output30c","key":"TrHKrYjNl9"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"Program 31","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"WQm5z6PxaZ"}],"identifier":"program-31","label":"Program 31","html_id":"program-31","implicit":true,"key":"yBIVbKzB8j"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p31.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, SpectralMethodsTrefethen, SpecialFunctions\n\"p31 - gamma function via complex integral, trapezoid rule\"\nfunction p31(N = 70, c = -11, r = 16)\n    # points on circle of integration:\n    t = [c + r * cispi(q) for q in 2 * (0.5:N-0.5) / N]\n    # trapezoid integration:\n    gaminv(z) = sum(exp(t) * t^(-z) * (t - c) for t in t) / N\n\n    x, y = range(-3.5, 4, 121), range(-2.5, 2.5, 121)\n    Γ = [1 / gaminv(complex(x, y)) for x in x, y in y]\n    fig = Figure(size=(700, 500))\n    ax = Axis3(fig[1, 1]; xlabel=\"Re(z)\", ylabel=\"Im(z)\", zlabel=\"|Γ(z)|\")\n    G = @. min(6, abs(Γ))\n    plt = surface!(ax, x, y, G; colormap=:lajolla, colorscale=log2, colorrange=(1e-2, 6))\n    Colorbar(fig[1, 2], plt)\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p31","identifier":"p31","filename":"p31","html_id":"p31","key":"FDrhgy0a9Q"}],"key":"H08HnsETiH"},{"type":"heading","depth":3,"position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"text","value":"Output 31","position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"key":"drZ1vNUH38"}],"identifier":"output-31","label":"Output 31","html_id":"output-31","implicit":true,"key":"HBPUbx1QNs"}],"key":"ASLcMXlrcH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p31()","identifier":"output31-code","html_id":"output31-code","key":"NsfdW73DBn"},{"type":"outputs","id":"yqzvkEL6tXbR0vq1R8Rqd","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"d02fa68c81764c45fd5ffaa9d02bfcb2","path":"https://tobydriscoll.net/S