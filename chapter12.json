{"version":3,"kind":"Notebook","sha256":"22817c8562189ce729d0d1ce823aa4d24653d75f3ecc36df88e639821ee396de","slug":"chapter12","location":"/chapter12.md","dependencies":[],"frontmatter":{"title":"Chapter 12","subtitle":"Functions clencurt, gauss, Programs p30, p31","kernelspec":{"name":"julia-1.11","display_name":"Julia 1","language":"julia"},"github":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl","numbering":{"title":{"enabled":false},"code":{"enabled":false},"equation":{"enabled":false},"heading_1":{"enabled":false},"heading_2":{"enabled":false},"heading_3":{"enabled":false},"heading_4":{"enabled":false},"heading_5":{"enabled":false},"heading_6":{"enabled":false}},"math":{"\\float":{"macro":"\\mathbb{F}"},"\\real":{"macro":"\\mathbb{R}"},"\\complex":{"macro":"\\mathbb{C}"},"\\nat":{"macro":"\\mathbb{N}"},"\\integer":{"macro":"\\mathbb{Z}"},"\\rmn":{"macro":"\\mathbb{R}^{#1 \\times #2}"},"\\dd":{"macro":"\\frac{d #1}{d #2}"},"\\ddd":{"macro":"\\frac{d^2 #1}{d #2^2}"},"\\pp":{"macro":"\\frac{\\partial #1}{\\partial #2}"},"\\ppp":{"macro":"\\frac{\\partial^2 #1}{\\partial #2^2}"},"\\ppdd":{"macro":"\\frac{\\partial^2 #1}{\\partial #2 \\partial #3}"},"\\abs":{"macro":"\\left\\lvert #1 \\right\\rvert"},"\\norm":{"macro":"\\left\\lVert #1 \\right\\rVert"},"\\twonorm":{"macro":"\\norm{#1}_2"},"\\onenorm":{"macro":"\\norm{#1}_1"},"\\infnorm":{"macro":"\\norm{#1}_\\infty"},"\\anynorm":{"macro":"\\norm{#1}_#2"},"\\innerprod":{"macro":"\\langle #1,#2 \\rangle"},"\\pr":{"macro":"^{(#1)}"},"\\kron":{"macro":"#1 \\otimes #2"},"\\macheps":{"macro":"\\epsilon_\\text{mach}"},"\\fl":{"macro":"\\operatorname{fl}"},"\\diag":{"macro":"\\operatorname{diag}"},"\\ign":{"macro":"\\operatorname{sign}"},"\\Re":{"macro":"\\operatorname{Re}"},"\\Im":{"macro":"\\operatorname{Im}"},"\\ee":{"macro":"\\times 10^"},"\\floor":{"macro":"\\lfloor#1\\rfloor"}},"abbreviations":{"SMiM":"Spectral Methods in MATLAB","IVP":"initial-value problem","BVP":"boundary-value problem","TPBVP":"two-point boundary-value problem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter12.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter12.md","exports":[{"format":"md","filename":"chapter12.md","url":"https://tobydriscoll.net/SMiJ/build/chapter12-ce0247793717f43d923a22dc28028494.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 30","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"ofo9DqgtGq"}],"identifier":"program-30","label":"Program 30","html_id":"program-30","implicit":true,"key":"zsoQmhtr6g"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p30.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings\nusing SpectralMethodsTrefethen, SpecialFunctions\n\"\"\"\np30 - spectral integration, ODE style (compare p12)\\n\n   use `chebweights`, `clencurt`, or `gauss` as the argument\n\"\"\"\nfunction p30(quadrule=chebweights)\n    # Computation: various values of N, four functions:\n    Nmax = 50\n    funs = [x -> abs(x)^3         x -> exp(-x^(-2));\n            x -> 1 / (1 + x^2)    x -> x^10]\n    ints = [1/2 2*(exp(-1) + sqrt(π) * (erf(1) - 1));  π/2 2/11]\n    E = zeros(2, 2, Nmax)\n    for N = 1:Nmax\n        x, w = quadrule(N)\n        for (i, f) in pairs(funs)\n            E[i, N] = abs(dot(w, f.(x)) - ints[i])\n        end\n    end\n\n    # Plot results:\n    fig = Figure()\n    titles = [L\"|x|^3\"  L\"\\exp(-x^2)\"; L\"1/(1+x^2)\"  L\"x^{10}\"]\n    ax = [Axis(fig[i, j]; title=titles[i, j], yscale=log10) for i in 1:2, j in 1:2]\n    linkaxes!(ax...)\n    @. E[iszero(E)] = NaN\n    for (i, ax) in pairs(ax)\n        scatterlines!(ax, 1:Nmax, E[i, :])\n    end\n    ax[1, 1].ylabel = ax[2, 1].ylabel = \"error\"\n    ax[2, 1].xlabel = ax[2, 2].xlabel = L\"N\"\n    return fig\nend\n\nfunction chebweights(N)\n    i = 1:N\n    D, x = cheb(N)\n    x = x[i]\n    w = inv(D[i, i])[1, :]\n    return x, w\nend","lang":"julia","showLineNumbers":true,"label":"p30","identifier":"p30","filename":"p30","html_id":"p30","key":"lAulgsPFTp"}],"key":"Ik3tGDJoCg"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"By default, ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"GOVVDu67qJ"},{"type":"crossReference","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Program 30","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"hvtplQylom"}],"identifier":"p30","label":"p30","kind":"code","template":"Code","resolved":true,"html_id":"p30","key":"DnvkhnTYqA"},{"type":"text","value":" computes quadrature weights by inverting a Chebyshev differentiation matrix, as in the text. I put that step into a function called ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"IPj36dKYKP"},{"type":"inlineCode","value":"chebweights","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"AK5ilRIgA5"},{"type":"text","value":", which is replaceable by the other two quadrature formulas in the chapter.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"l2c2r1yy1g"}],"key":"zjAiEzWfg9"},{"type":"heading","depth":3,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Output 30","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"arodullOYi"}],"identifier":