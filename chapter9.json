"value":"The ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"vhc9F1LCue"},{"type":"inlineCode","value":"findfirst","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"rw4gAkOw8K"},{"type":"text","value":" function returns the index of the first element of an array that satisfies a given condition. The result is either ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"JsjMHsiYOR"},{"type":"inlineCode","value":"nothing","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"UEFYu5TLwa"},{"type":"text","value":", if no elements satisfy the condition, or an integer index. I have used the syntax ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"OPN8HN5dff"},{"type":"inlineCode","value":">(0)","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"gcXJRxkNN8"},{"type":"text","value":" to create an anonymous function that tests whether its argument is greater than zero, shorthand for ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"KZEbMR9MXI"},{"type":"inlineCode","value":"x -> x > 0","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"Zwscvc9aaW"},{"type":"text","value":". Finally, we want the 5th index of the result, so I add 4 since they are in sorted order.","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"GeuFvVVUmk"}],"key":"H7iGIhEYtm"}],"icon":false,"class":"dropdown","key":"RAN9Uc74fC"},{"type":"heading","depth":2,"position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"Program 23","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"PkG25vAEpU"}],"identifier":"program-23","label":"Program 23","html_id":"program-23","implicit":true,"key":"dyu4guNn92"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p23.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, Printf, LaTeXStrings\nusing LinearAlgebra, SpectralMethodsTrefethen\n\"\"\"\n# p23 - eigenvalues of perturbed Laplacian on [-1,1] x [-1,1] (compare p16)\n\"\"\"\nfunction p23(N=16; perturb=false)\n    # Set up tensor product Laplacian and compute 4 eigenmodes:\n    D, x = cheb(N)\n    y = x\n\n    D² = (D^2)[2:N, 2:N]\n    Δ = -kron(I(N-1), D²) - kron(D², I(N-1))    # Laplacian\n    if perturb\n        F = [exp(20 * (y - x - 1)) for x in x[2:N], y in y[2:N]]\n        Δ += Diagonal(vec(F))\n    end\n    λ, V = eigen(Δ)\n\n    # Reshape them to 2D grid, interpolate to finer grid, and plot:\n    xx = yy = range(-1, 1, 101)\n    U = zeros(N+1, N+1)\n    fig = Figure(size=(600, 600))\n    modes = [1 2; 3 4]\n    ax = [Axis(fig[i, j]; aspect=1) for i in 1:2, j in 1:2]\n    for (i, mode) in pairs(modes)\n        U[2:N, 2:N] = reshape(V[:, mode], N-1, N-1)\n        UU = interp2dgrid(U, chebinterp, chebinterp, xx, yy)\n        UU /= maximum(abs, UU)\n        str = @sprintf(\"λ = %0.12f π^2/4\", 4λ[mode] / π^2)\n        contourf!(ax[i], xx, yy, UU; levels=-1.1:0.2:1.1, colormap=:redsblues)\n        ax[i].title = str\n        hidedecorations!(ax[i], ticks=false)\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p23","identifier":"p23","filename":"p23","html_id":"p23","key":"krPatOpWlz"}],"key":"yeyFIuH82P"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Output 23a","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"MQXcXtEDdz"}],"identifier":"output-23a","label":"Output 23a","html_id":"output-23a","implicit":true,"key":"kPGU5CuUKl"},{"type":"paragraph","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Both versions of ","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"wEPdcORGR