{"version":3,"kind":"Notebook","sha256":"c643d611a7020dc528120d9cbe2050d97c82292dde81bfdc031082fd1dcac4b4","slug":"chapter9","location":"/chapter9.md","dependencies":[],"frontmatter":{"title":"Chapter 9","subtitle":"Programs p21, p22, p23, p24","kernelspec":{"name":"julia-1.11","display_name":"Julia 1","language":"julia"},"github":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl","numbering":{"title":{"enabled":false},"code":{"enabled":false},"equation":{"enabled":false},"heading_1":{"enabled":false},"heading_2":{"enabled":false},"heading_3":{"enabled":false},"heading_4":{"enabled":false},"heading_5":{"enabled":false},"heading_6":{"enabled":false}},"math":{"\\float":{"macro":"\\mathbb{F}"},"\\real":{"macro":"\\mathbb{R}"},"\\complex":{"macro":"\\mathbb{C}"},"\\nat":{"macro":"\\mathbb{N}"},"\\integer":{"macro":"\\mathbb{Z}"},"\\rmn":{"macro":"\\mathbb{R}^{#1 \\times #2}"},"\\dd":{"macro":"\\frac{d #1}{d #2}"},"\\ddd":{"macro":"\\frac{d^2 #1}{d #2^2}"},"\\pp":{"macro":"\\frac{\\partial #1}{\\partial #2}"},"\\ppp":{"macro":"\\frac{\\partial^2 #1}{\\partial #2^2}"},"\\ppdd":{"macro":"\\frac{\\partial^2 #1}{\\partial #2 \\partial #3}"},"\\abs":{"macro":"\\left\\lvert #1 \\right\\rvert"},"\\norm":{"macro":"\\left\\lVert #1 \\right\\rVert"},"\\twonorm":{"macro":"\\norm{#1}_2"},"\\onenorm":{"macro":"\\norm{#1}_1"},"\\infnorm":{"macro":"\\norm{#1}_\\infty"},"\\anynorm":{"macro":"\\norm{#1}_#2"},"\\innerprod":{"macro":"\\langle #1,#2 \\rangle"},"\\pr":{"macro":"^{(#1)}"},"\\kron":{"macro":"#1 \\otimes #2"},"\\macheps":{"macro":"\\epsilon_\\text{mach}"},"\\fl":{"macro":"\\operatorname{fl}"},"\\diag":{"macro":"\\operatorname{diag}"},"\\ign":{"macro":"\\operatorname{sign}"},"\\Re":{"macro":"\\operatorname{Re}"},"\\Im":{"macro":"\\operatorname{Im}"},"\\ee":{"macro":"\\times 10^"},"\\floor":{"macro":"\\lfloor#1\\rfloor"}},"abbreviations":{"SMiM":"Spectral Methods in MATLAB","IVP":"initial-value problem","BVP":"boundary-value problem","TPBVP":"two-point boundary-value problem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter9.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter9.md","exports":[{"format":"md","filename":"chapter9.md","url":"https://tobydriscoll.net/SMiJ/build/chapter9-c301b34bcc99373dd6c066ea5883d945.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 21","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"zbzmh69CBH"}],"identifier":"program-21","label":"Program 21","html_id":"program-21","implicit":true,"key":"HcVUAT9k6T"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p21.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, LinearAlgebra, ToeplitzMatrices\n\"\"\"\np21 - eigenvalues of Mathieu operator -u_xx + 2 q cos(2x) u\\n\n         (compare p8 and p. 724 of Abramowitz & Stegun)\n\"\"\"\nfunction p21(N = 42)\n    h = 2π / N\n    x = h * (1:N)\n    c0 = -π^2 / 3h^2 - 1 / 6\n    col = [c0; [ (-1)^(j+1) / 2sin(h * j / 2)^2 for j in 1:N-1 ]]\n    D² = Toeplitz(col, col)    # second-order differentiation matrix\n    q = 0:.2:15\n    data = zeros(11, length(q))\n    for (i, q) in enumerate(q)\n        λ = eigvals( -D² + 2q * Diagonal(cos.(2x)) )\n        data[:, i] = λ[1:11]\n    end\n    fig = Figure(size=(320, 500))\n    ax = Axis(fig[1, 1]; xlabel=L\"q\", ylabel=L\"λ\", yticks=-24:4:32,\n        limits=(0, 15, -24, 32))\n    series!(ax, q, data[1:2:end, :], color=:atlantic)\n    series!(ax, q, data[2:2:end, :], linestyle=:dot, color=:atlantic)\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p21","identifier":"p21","filename":"p21","html_id":"p21","key":"PFSAdsOoi9"}],"key":"wpNwXy3xCy"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Output 21","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"ogGNVMTB7n"}],"identifier":"output-21","label":"Output 21","html_id":"output-21","implicit":true,"key":"iy9lQ2OCH3"}],"key":"wDrxIc7naW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"using SpectralMethodsTrefethen\np21()","identifier":"output21-code","html_id":"output21-code","key":"HahU74isHU"},{"type":"outputs","id":"KGZIfgkM7GIYIqBOh4ioE","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"57e07efe2c6495978a0e940af709f6df","path":"https://tobydriscoll.net/SMiJ/build/57e07efe2c6495978a0e940af709f6df.png"},"text/html":{"content_type":"text/html","hash":"a4d7f232c45050b416fdcdc40f096838","path":"https://tobydriscoll.net/SMiJ/build/a4d7f232c45050b416fdcdc40f096838.html"}}},"identifier":"output21-outputs-0","html_id":"output21-outputs-0","key":"TpOmkNXy1K"}],"identifier":"output21-outputs","html_id":"output21-outputs","key":"e1WHXlD8jb"}],"label":"output21","identifier":"output21","html_id":"output21","key":"aa9Zbi2LLW"},{"type":"block","children":[{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"inlineCode","value":"series","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"X2wzU282Do"},{"type":"text","value":" plot","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"Am31Hzitnn"}],"key":"aACHvZO49s"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"ch