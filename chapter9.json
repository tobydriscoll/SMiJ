thodsTrefethen\n\"\"\"\n# p23 - eigenvalues of perturbed Laplacian on [-1,1] x [-1,1] (compare p16)\n\"\"\"\nfunction p23(N=16; perturb=false)\n    # Set up tensor product Laplacian and compute 4 eigenmodes:\n    D, x = cheb(N)\n    y = x\n\n    D¬≤ = (D^2)[2:N, 2:N]\n    őĒ = -kron(I(N-1), D¬≤) - kron(D¬≤, I(N-1))    # Laplacian\n    if perturb\n        F = [exp(20 * (y - x - 1)) for x in x[2:N], y in y[2:N]]\n        őĒ += Diagonal(vec(F))\n    end\n    őĽ, V = eigen(őĒ)\n\n    # Reshape them to 2D grid, interpolate to finer grid, and plot:\n    xx = yy = range(-1, 1, 101)\n    U = zeros(N+1, N+1)\n    fig = Figure(size=(600, 600))\n    modes = [1 2; 3 4]\n    ax = [Axis(fig[i, j]; aspect=1) for i in 1:2, j in 1:2]\n    for (i, mode) in pairs(modes)\n        U[2:N, 2:N] = reshape(V[:, mode], N-1, N-1)\n        UU = interp2dgrid(U, chebinterp, chebinterp, xx, yy)\n        UU /= maximum(abs, UU)\n        str = @sprintf(\"őĽ = %0.12f ŌÄ^2/4\", 4őĽ[mode] / ŌÄ^2)\n        contourf!(ax[i], xx, yy, UU; levels=-1.1:0.2:1.1, colormap=:redsblues)\n        ax[i].title = str\n        hidedecorations!(ax[i], ticks=false)\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p23","identifier":"p23","filename":"p23","html_id":"p23","key":"E7jsbxYMA3"}],"key":"e40YFCjzpd"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Output 23a","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"a19PnpCRng"}],"identifier":"output-23a","label":"Output 23a","html_id":"output-23a","implicit":true,"key":"i74sfAfrJD"},{"type":"paragraph","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Both versions of ","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"QBlCXq0YFX"},{"type":"inlineCode","value":"p23","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}