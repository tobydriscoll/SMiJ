roblem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter9.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter9.md","exports":[{"format":"md","filename":"chapter9.md","url":"/build/chapter9-c301b34bcc99373dd6c066ea5883d945.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 21","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"cyuooNoqAV"}],"identifier":"program-21","label":"Program 21","html_id":"program-21","implicit":true,"key":"legKCvfF6a"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p21.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, LinearAlgebra, ToeplitzMatrices\n\"\"\"\np21 - eigenvalues of Mathieu operator -u_xx + 2 q cos(2x) u\\n\n         (compare p8 and p. 724 of Abramowitz & Stegun)\n\"\"\"\nfunction p21(N = 42)\n    h = 2ŌÄ / N\n    x = h * (1:N)\n    c0 = -ŌÄ^2 / 3h^2 - 1 / 6\n    col = [c0; [ (-1)^(j+1) / 2sin(h * j / 2)^2 for j in 1:N-1 ]]\n    D¬≤ = Toeplitz(col, col)    # second-order differentiation matrix\n    q = 0:.2:15\n    data = zeros(11, length(q))\n    for (i, q) in enumerate(q)\n        őĽ = eigvals( -D¬≤ + 2q * Diagonal(cos.(2x)) )\n        data[:, i] = őĽ[1:11]\n    end\n    fig = Figure(size=(320, 500))\n    ax = Axis(fig[1, 1]; xlabel=L\"q\", ylabel=L\"őĽ\", yticks=-24:4:32,\n        limits=(0, 15, -24, 32))\n    series!(ax, q, data[1:2:end, :], color=:atlantic)\n    series!(ax, q, data[2:2:end, :], linestyle=:dot, color=:atlantic)\n    return fig\nend","lan