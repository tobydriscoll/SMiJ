e":64,"column":1},"end":{"line":64,"column":1}},"key":"sw6mlndGRn"},{"type":"inlineCode","value":"findfirst","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"muBlBy7mZ6"},{"type":"text","value":" function returns the index of the first element of an array that satisfies a given condition. The result is either ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"pxYdwNSF7X"},{"type":"inlineCode","value":"nothing","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"MQX8ybikEY"},{"type":"text","value":", if no elements satisfy the condition, or an integer index. I have used the syntax ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"alCTfavJva"},{"type":"inlineCode","value":">(0)","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"PP1WiHb1Ej"},{"type":"text","value":" to create an anonymous function that tests whether its argument is greater than zero, shorthand for ","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"X1sDKAOWcF"},{"type":"inlineCode","value":"x -> x > 0","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"VffoAD1Ig1"},{"type":"text","value":". Finally, we want the 5th index of the result, so I add 4 since they are in sorted order.","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"I0j6o52T5N"}],"key":"Ue9Kdwxe6Q"}],"icon":false,"class":"dropdown","key":"OJioSknEch"},{"type":"heading","depth":2,"position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"Program 23","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"P4fjG1H7RX"}],"identifier":"program-23","label":"Program 23","html_id":"program-23","implicit":true,"key":"EJIDTkony6"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p23.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, Printf, LaTeXStrings\nusing LinearAlgebra, SpectralMethodsTrefethen\n\"\"\"\n# p23 - eigenvalues of perturbed Laplacian on [-1,1] x [-1,1] (compare p16)\n\"\"\"\nfunction p23(N=16; perturb=false)\n    # Set up tensor product Laplacian and compute 4 eigenmodes:\n    D, x = cheb(N)\n    y = x\n\n    D² = (D^2)[2:N, 2:N]\n    Δ = -kron(I(N-1), D²) - kron(D², I(N-1))    # Laplacian\n    if perturb\n        F = [exp(20 * (y - x - 1)) for x in x[2:N], y in y[2:N]]\n        Δ += Diagonal(vec(F))\n    end\n    λ, V = eigen(Δ)\n\n    # Reshape them to 2D grid, interpolate to finer grid, and plot:\n    xx = yy = range(-1, 1, 101)\n    U = zeros(N+1, N+1)\n    fig = Figure(size=(600, 600))\n    modes = [1 2; 3 4]\n    ax = [Axis(fig[i, j]; aspect=1) for i in 1:2, j in 1:2]\n    for (i, mode) in pairs(modes)\n        U[2:N, 2:N] = reshape(V[:, mode], N-1, N-1)\n        UU = interp2dgrid(U, chebinterp, chebinterp, xx, yy)\n        UU /= maximum(abs, UU)\n        str = @sprintf(\"λ = %0.12f π^2/4\", 4λ[mode] / π^2)\n        contourf!(ax[i], xx, yy, UU; levels=-1.1:0.2:1.1, colormap=:redsblues)\n        ax[i].title = str\n        hidedecorations!(ax[i], ticks=false)\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p23","identifier":"p23","filename":"p23","html_id":"p23","key":"vRUdDfGnsZ"}],"key":"vapTPFtB49"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Output 23a","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"SQtgwtBR6U"}],"identifier":"output-23a","label":"Output 23a","html_id":"output-23a","implicit":true,"key":"akRRUNc3Rl"},{"type":"paragraph","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Both versions of ","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"nNDexPCcx0"},{"type":"inlineCode","value":"p23","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"GodwKMEU4O"},{"type":"text","value":" are so similar that I have put them into a single function with a keyword argument to control the perturbation.","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"NQbn5dtMbo"}],"key":"OfbiDKcYJi"}],"key":"MF5n4pX4s7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p23()","identifier":"output23a-code","html_id":"output23a-code","key":"ViZYkiiGDJ"},{"type":"outputs","id":"8_q7ARvWBZYPd312X9FWv","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":3,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"21c5dd3467fc72d8c1502d47e0645807","path":"tobydriscoll.net/SMiJ/build/21c5dd3467fc72d8c1502d47e0645807.png"},"text/html":{"content_type":"text/html","hash":"82ddd17d4c45e1d2fbc5352941c28fa4","path":"tobydriscoll.net/SMiJ/build/82ddd17d4c45e1d2fbc5352941c28fa4.html"}}},"identifier":"output23a-outputs-0","html_id":"output23a-outputs-0","key":"IbXRm0O86S"}],"identifier":"output23a-outputs","html_id":"output23a-outputs","key":"sWX0yxm6cM"}],"label":"output23a","identifier":"output23a","html_id":"output23a","key":"nFZcwHUGYM"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"text","value":"Output 23b","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"XI76hvtMun"}],"identifier":"output-23b","label":"Output 23b","html_id":"output-23b","implicit":true,"key":"uJ6lSBI4zt"}],"key":"KyCjJmyKvg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p23(perturb=true)","identifier":"output23b-code","html_id":"output23b-code","key":"iRVkmWVqxX"},{"type":"outputs","id":"BHe-o0J0eMbhWSzh4hz1u","children":[{"type":"output","children"