alternatives.","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"key":"qw22ToxGU5"}],"key":"RAQMFRBwoT"}],"icon":false,"class":"dropdown","key":"L0By7qaUC9"},{"type":"heading","depth":2,"position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"Program 24","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"M2Iv7JhNYW"}],"identifier":"program-24","label":"Program 24","html_id":"program-24","implicit":true,"key":"XnQaiVI1Du"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p24.jl","literal":true,"children":[{"type":"code","value":"using  CairoMakie, LinearAlgebra, SpectralMethodsTrefethen\n\"p24 - pseudospectra of Davies's complex harmonic oscillator\"\nfunction p24(N=70, L=6)\n    # Eigenvalues:\n    D, x = cheb(N)\n    x, D = L * x, D / L            # rescale to [-L,L]\n    A = -D^2 + (1 + 3im) * Diagonal(x .^ 2)\n    A = A[2:N, 2:N]\n    λ = eigvals(A)\n\n    # Pseudospectra:\n    fig = Figure()\n    ax = Axis(fig[1, 1]; xlabel=L\"\\mathrm{Re}(z)\", ylabel=L\"\\mathrm{Im}(z)\",\n        limits=(0, 50, 0, 40), aspect=DataAspect())\n    x, y = 0:0.5:50, 0:0.5:40\n    minsigma(z) = minimum(svdvals(z * I - A))\n    σ_min = [minsigma(complex(x, y)) for x in x, y in y]\n    cplt = contourf!(x, y, log10.(σ_min); colormap=:Blues, levels=-5:0.5:-0.5)\n    scatter!(ax, reim(λ)...; color=:orange, markersize=6)\n    Colorbar(fig[1, 2], cplt)\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p24","identifier":"p24","filename":"p24","html_id":"p24","key":"J8Tg0irrZs"}],"key":"xpHHwTzsb9"},{"type":"heading","depth":3,"position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"Output 24","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"JTV4N5TC4N"}],"identifier":"output-24","label":"Output 24","html_id":"output-24","implicit":true,"key":"mQ3O6CyMih"}],"key":