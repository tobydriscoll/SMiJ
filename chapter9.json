h3uXM"}],"key":"WCFvG4Pndk"},{"type":"paragraph","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"children":[{"type":"text","value":"Julia lets you achieve many things in multiple ways. Often, it doesn‚Äôt matter much which you choose. But if a key section of code is taking more time than you like, Julia gives you the tools and fine-grained control to try alternatives.","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"key":"V3tSrXEfZu"}],"key":"m901mRGKDZ"}],"icon":false,"class":"dropdown","key":"xYmsZqN2FN"},{"type":"heading","depth":2,"position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"Program 24","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"b47NUpjxuj"}],"identifier":"program-24","label":"Program 24","html_id":"program-24","implicit":true,"key":"qAfssnD3WP"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p24.jl","literal":true,"children":[{"type":"code","value":"using  CairoMakie, LinearAlgebra, SpectralMethodsTrefethen\n\"p24 - pseudospectra of Davies's complex harmonic oscillator\"\nfunction p24(N=70, L=6)\n    # Eigenvalues:\n    D, x = cheb(N)\n    x, D = L * x, D / L            # rescale to [-L,L]\n    A = -D^2 + (1 + 3im) * Diagonal(x .^ 2)\n    A = A[2:N, 2:N]\n    őĽ = eigvals(A)\n\n    # Pseudospectra:\n    fig = Figure()\n    ax = Axis(fig[1, 1]; xlabel=L\"\\mathrm{Re}(z)\", ylabel=L\"\\mathrm{Im}(z)\",\n        limits=(0, 50, 0, 40), aspect=DataAspect())\n    x, y = 0:0.5:50, 0:0.5:40\n    minsigma(z) = minimum(svdvals(z * I - A))\n    ŌÉ_min = [minsigma(complex(x, y)) for x in x, y in y]\n    cplt = contourf!(x, y, log10.(ŌÉ_min); colormap=:Blues, levels=-5:0.5:-0.5)\n    scatter!(ax, reim(őĽ)...; color=:orange, markersize=6)\n    Colorbar(fig[1, 2], cplt)\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p24","identifier":"p24","filename":"p24","html_id":"p24","key":"Bf3V1dmGDg"}],"key":"Epod1LY39K"},{"type":"heading","depth":3,"position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"Output 24","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"sPKrK8HuCe"}],"identifier":"output-24","label":"Output 24","html_id":"output-24","implicit":true,"key":"TP6AfnoIBI"}],"key":"KTnOXu8q03"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p24()","identifier":"output24-code","html_id":"output24-code","key":"vkPOBjjjJ9"},{"type":"outputs","id":"tJbg57YSfTj9v9StswiM1","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e3112169bcfd93885125dbfa54ca6d22","path":"https://tobydriscoll.net/build/e3112169bcfd93885125dbfa54ca6d22.png"},"text/html":{"content_type":"text/html","hash":"b4f5406d0f70a3a0b54ced4baec1c1f6","path":"https://tobydriscoll.net/build/b4f5406d0f70a3a0b54ced4baec1c1f6.html"}}},"identifier":"output24-outputs-0","html_id":"output24-outputs-0","key":"zHJyOAJdck"}],"identifier":"output24-outputs","html_id":"output24-outputs","key":"ZVGVa535yk"}],"label":"output24","identifier":"output24","html_id":"output24","key":"a4fnMbGA0P"}],"key":"FzLbtS5b2u"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Chapter 8","url":"/chapter8","group":"Spectral Methods in Julia"},"next":{"title":"Chapter 10","url":"/chapter10","group":"Spectral Methods in Julia"}}},"domain":"http://localhost:3004"}