) + 4\n        őĽ, v = őĽ[fifth], V[:, fifth]\n        v = [0; v; 0]                           # extend to booundary\n        v = v / v[div(N, 2) + 1] * airyai(0)    # normalize\n        u = chebinterp(v)\n        lines(fig[i[1], i[2]], -1..1, u;\n            axis=(; title=@sprintf(\"N = %d,  őĽ = %0.10f\", N, őĽ)))\n    end\n    return fig\nend\n","lang":"julia","showLineNumbers":true,"label":"p22","identifier":"p22","filename":"p22","html_id":"p22","key":"Xj3L7SnSUV"}],"key":"xdvFImIFWA"},{"type":"heading","depth":3,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"Output 22","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"AhcOC5EyER"}],"identifier":"output-22","label":"Output 22","html_id":"output-22","implicit":true,"key":"D3WB2rxkbb"}],"key":"hlftZ1Ghep"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p22()","identifier":"output22-code","html_id":"output22-code","key":"NMBVE3yaMt"},{"type":"outputs","id":"FhttkvDmiUd6NHz6sxc7I","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":2,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"4138c3e8e13f090dea2e526f1c1087b1","path":"/build/4138c3e8e13f090dea2e526f1c1087b1.png"},"text/html":{"content_type":"text/html","hash":"9c60fae4353882d328fe70fd6fc8d840","path":"/build/9c60fae4353882d328fe70fd6fc8d840.html"}}},"identifier":"output22-outputs-0","html_id":"output22-outputs-0","key":"XlP9v4c8DM"}],"identifier":"output22-outputs","html_id":"output22-outputs","key":"AnDYk0jHLd"}],"label":"output22","identifier":"output22","html_id":"output22","key":"ggiSnnsp9v"},{"type":"block","children":[{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Generalized eigenvalue problem","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},