roblem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter9.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter9.md","exports":[{"format":"md","filename":"chapter9.md","url":"https://tobydriscoll.net/build/chapter9-c301b34bcc99373dd6c066ea5883d945.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 21","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"rgJYzusF2X"}],"identifier":"program-21","label":"Program 21","html_id":"program-21","implicit":true,"key":"N6sOlmeGvk"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p21.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, LaTeXStrings, LinearAlgebra, ToeplitzMatrices\n\"\"\"\np21 - eigenvalues of Mathieu operator -u_xx + 2 q cos(2x) u\\n\n         (compare p8 and p. 724 of Abramowitz & Stegun)\n\"\"\"\nfunction p21(N = 42)\n    h = 2ŌÄ / N\n    x = h * (1:N)\n    c0 = -ŌÄ^2 / 3h^2 - 1 / 6\n    col = [c0; [ (-1)^(j+1) / 2sin(h * j / 2)^2 for j in 1:N-1 ]]\n    D¬≤ = Toeplitz(col, col)    # second-order differentiation matrix\n    q = 0:.2:15\n    data = zeros(11, length(q))\n    for (i, q) in enumerate(q)\n        őĽ = eigvals( -D¬≤ + 2q * Diagonal(cos.(2x)) )\n        data[:, i] = őĽ[1:11]\n    end\n    fig = Figure(size=(320, 500))\n    ax = Axis(fig[1, 1]; xlabel=L\"q\", ylabel=L\"őĽ\", yticks=-24:4:32,\n        limits=(0, 15, -24, 32))\n    series!(ax, q, data[1:2:end, :], color=:atlantic)\n    series!(ax, q, data[2:2:end, :], linestyle=:dot, color=:atlantic)\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p21","identifier":"p21","filename":"p21","html_id":"p21","key":"QtvppYPDO2"}],"key":"r1cawTlGVn"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Output 21","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"w97fhCGHfi"}],"identifier":"output-21","label":"Output 21","html_id":"output-21","implicit":true,"key":"LxGVt7Ztcp"}],"key":"WUcPv9gdMn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"using SpectralMethodsTrefethen\np21()","identifier":"output21-code","html_id":"output21-code","key":"d4V5Hw6Nct"},{"type":"outputs","id":"1R6UGjtVR5yOz0YcEgxct","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"57e07efe2c6495978a0e940af709f6df","path":"https://tobydriscoll.net/build/57e07efe2c6495978a0e940af709f6df.png"},"text/html":{"content_type":"text/html","hash":"a4d7f232c45050b416fdcdc40f096838","path":"https://tobydriscoll.net/build/a4d7f232c45050b416fdcdc40f096838.html"}}},"identifier":"output21-outputs-0","html_id":"output21-outputs-0","key":"H8T5V4qNAE"}],"identifier":"output21-outputs","html_id":"output21-outputs","key":"xJqxwKcLf9"}],"label":"output21","identifier":"output21","html_id":"output21","key":"nWq75ov3tJ"},{"type":"block","children":[{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"inlineCode","value":"series","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"hVDHlzKN75"},{"type":"text","value":" plot","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"jlnLjOWc1H"}],"key":"MSuCCZZA7G"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":