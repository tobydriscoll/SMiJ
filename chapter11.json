{"version":3,"kind":"Notebook","sha256":"151a7ba4c2e555d7fcdba568ee1a34a6627a4592ff156dfa38371e3954b38a53","slug":"chapter11","location":"/chapter11.md","dependencies":[],"frontmatter":{"title":"Chapter 11","subtitle":"Programs p28, p29","kernelspec":{"name":"julia-1.11","display_name":"Julia 1","language":"julia"},"github":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl","numbering":{"title":{"enabled":false},"code":{"enabled":false},"equation":{"enabled":false},"heading_1":{"enabled":false},"heading_2":{"enabled":false},"heading_3":{"enabled":false},"heading_4":{"enabled":false},"heading_5":{"enabled":false},"heading_6":{"enabled":false}},"math":{"\\float":{"macro":"\\mathbb{F}"},"\\real":{"macro":"\\mathbb{R}"},"\\complex":{"macro":"\\mathbb{C}"},"\\nat":{"macro":"\\mathbb{N}"},"\\integer":{"macro":"\\mathbb{Z}"},"\\rmn":{"macro":"\\mathbb{R}^{#1 \\times #2}"},"\\dd":{"macro":"\\frac{d #1}{d #2}"},"\\ddd":{"macro":"\\frac{d^2 #1}{d #2^2}"},"\\pp":{"macro":"\\frac{\\partial #1}{\\partial #2}"},"\\ppp":{"macro":"\\frac{\\partial^2 #1}{\\partial #2^2}"},"\\ppdd":{"macro":"\\frac{\\partial^2 #1}{\\partial #2 \\partial #3}"},"\\abs":{"macro":"\\left\\lvert #1 \\right\\rvert"},"\\norm":{"macro":"\\left\\lVert #1 \\right\\rVert"},"\\twonorm":{"macro":"\\norm{#1}_2"},"\\onenorm":{"macro":"\\norm{#1}_1"},"\\infnorm":{"macro":"\\norm{#1}_\\infty"},"\\anynorm":{"macro":"\\norm{#1}_#2"},"\\innerprod":{"macro":"\\langle #1,#2 \\rangle"},"\\pr":{"macro":"^{(#1)}"},"\\kron":{"macro":"#1 \\otimes #2"},"\\macheps":{"macro":"\\epsilon_\\text{mach}"},"\\fl":{"macro":"\\operatorname{fl}"},"\\diag":{"macro":"\\operatorname{diag}"},"\\ign":{"macro":"\\operatorname{sign}"},"\\Re":{"macro":"\\operatorname{Re}"},"\\Im":{"macro":"\\operatorname{Im}"},"\\ee":{"macro":"\\times 10^"},"\\floor":{"macro":"\\lfloor#1\\rfloor"}},"abbreviations":{"SMiM":"Spectral Methods in MATLAB","IVP":"initial-value problem","BVP":"boundary-value problem","TPBVP":"two-point boundary-value problem","SVD":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter11.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter11.md","exports":[{"format":"md","filename":"chapter11.md","url":"https://tobydriscoll.net/build/chapter11-54e14bb033e321d5357f01c3b6cdb2eb.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 28","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"Oo6D0gSQtD"}],"identifier":"program-28","label":"Program 28","html_id":"program-28","implicit":true,"key":"SzQQ4E7Ceo"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p28.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, Printf\nusing ToeplitzMatrices, LinearAlgebra, SpectralMethodsTrefethen\n\"p28 - eigenmodes of Laplacian on the disk (compare p22)\"\nfunction p28(N=25, M=20; version=:a)\n    @assert isodd(N) && iseven(M) \"Must choose odd N and even M\"\n    # r coordinate, ranging from -1 to 1 (N must be odd):\n    N2 = div(N-1, 2)\n    Dr, r = cheb(N)\n    D²r = Dr^2\n    D₁ = D²r[2:N2+1, 2:N2+1]\n    D₂ = D²r[2:N2+1, N:-1:N2+2]\n    E₁ = Dr[2:N2+1, 2:N2+1]\n    E₂ = Dr[2:N2+1, N:-1:N2+2]\n\n    # θ coordinate, ranging from 0 to 2π (M must be even):\n    dθ = 2π / M\n    θ = dθ * (1:M)\n    M2 = div(M, 2)\n    c0 = -π^2 / 3dθ^2 - 1 / 6\n    col = [0.5 * (-1)^(k + 1) / sin(k * dθ / 2)^2 for k in 1:M-1]\n    D²θ = Toeplitz([c0; col], [c0; col])\n\n    # Laplacian in polar coordinates:\n    R = Diagonal(1 ./ r[2:N2+1])\n    J = [zeros(M2, M2) I; I zeros(M2, M2)]\n    Δ = kron(D₁ + R * E₁, I(M)) + kron(D₂ + R * E₂, J) + kron(R^2, D²θ)\n\n    # Compute eigenmodes:\n    λ, W = eigen(-Δ, sortby=abs)\n    λ = sqrt.(real(λ / λ[1]))\n\n    function getmode(W, k, θ, r)\n        V = reshape(real(W[:, k]), M, N2)\n        V = [zeros(M) V / maximum(abs, V)]                # BC and normalize\n        V = [V V[(@. mod1(M2 + (1:M), M)), N2+1:-1:1]]    # extend to r < 0\n        return interp2dgrid(V, fourinterp, chebinterp, θ, r)\n    end\n\n    # Plot eigenmodes:\n    r, θ = range(-1, 1, 71), range(0, π, 111)\n    X = [r * cos(θ) for θ in θ, r in r]\n    Y = [r * sin(θ) for θ in θ, r in r]\n    zcirc = cispi.((-200:200) / 200)\n    fig = Figure(size=(640, 640))\n    if version == :a\n        modes = [1 3; 6 10]\n        for (i, mode) in pairs(modes)\n            str = @sprintf(\"Mode %d: λ = %0.11f\", mode, λ[mode])\n            U = getmode(W, mode, θ, r)\n            ax = Axis3(fig[i[1], i[2]]; title=str, aspect=:data)\n            surface!(ax, X, Y, 1.5 .+ U;\n                colormap=:redsblues, colorrange=(0.5, 2.5))\n            contour!(ax, X, Y, U; levels=[0], color=:darkblue, linewidth=1)\n            lines!(ax, reim(zcirc)...; color=:black, linewidth=2)\n            set_lights!(ax, [])\n            set_ambient_light!(ax, RGBf(0.85, 0.85, 0.85))\n            hidedecorations!(ax)\n            hidespines!(ax)\n        end\n    elseif version == :b\n        modes = reshape(1:25, 5, 5)'\n        for (i, mode) in pairs(modes)\n            str = @sprintf(\"%0.4f\", λ[mode])\n            U = getmode(W, mode, θ, r)\n            ax = Axis(fig[i[1], i[2]]; title=str, titlefont=:regular, aspect=DataAspect())\n            contour!(ax, X, Y, U; levels=[0], color=:darkblue, linewidth=1)\n            lines!(ax, reim(zcirc)...; color=:black, linewidth=2)\n            hidedecorations!(ax)\n            hidespines!(ax)\n        end\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p28","identifier":"p28","filename":"p28","html_id":"p28","key":"e3MOxfT9U5"}],"key":"oIZ20UakgY"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Output 28","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"dGRuocQcxb"}],"identifier":"output-28","label":"Output 28","html_id":"output-28","implicit":true,"key":"cjr9QxlA0s"}],"key":"Nu29kk2Vl7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"using SpectralMethodsTrefethen\np28()","identifier":"output28a-code","html_id":"output28a-code","key":"RbuPJdJLo0"},{"type":"outputs","id":"kWuU5bN5iSn2eVzmFNc8P","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"7aa3547cbd7ac9a73df3dba85d43922b","path":"https://tobydriscoll.net/build/7aa3547cbd7ac9a73df3dba85d43922b.png"},"text/html":{"content_type":"text/html","hash":"51f67721a203569a53c04620c02569f3","path":"https://tobydriscoll.net/build/51f67721a203569a53c04620c02569f3.html"}}},"identifier":"output28a-outputs-0","html_id":"output28a-outputs-0","key":"DiZFSo82pb"}],"identifier":"output28a-outputs","html_id":"output28a-outputs","key":"oBsakXOK2I"}],"label":"output28a","identifier":"output28a","html_id":"output28a","key":"ezOWNXI3WL"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"I found the outputs for this chapter in ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"v0Jylh0NeV"},{"type":"emphasis","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"abbreviation","title":"Spectral Methods in MATLAB","children":[{"type":"text","value":"SMiM","key":"vwtfi5UKJu"}],"key":"w2m4gHzNLK"}],"key":"aym69DpiZY"},{"type":"text","value":" to be a 