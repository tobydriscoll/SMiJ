\">.</mi></mrow><annotation encoding=\"application/x-tex\">[-1, 1.5].</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">[</span><span class=\"mord\">−</span><span class=\"mord\">1</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">1.5</span><span class=\"mclose\">]</span><span class=\"mord\">.</span></span></span></span>","key":"ZcDq96ocaJ"}],"key":"Dudr6M3zAn"}],"icon":false,"class":"dropdown","key":"OpRDb3sI9w"},{"type":"heading","depth":2,"position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"Program 10","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"zO8XXQi3AH"}],"identifier":"program-10","label":"Program 10","html_id":"program-10","implicit":true,"key":"LpHgNEf8N3"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p10.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, Polynomials\n\"p10 - polynomials and corresponding equipotential curves\"\nfunction p10(N = 16)\n    fig = Figure()\n    cases = (\n        (\"equispaced points\", [-1 + 2n / N for n in 0:N]),\n        (\"Chebyshev points\", [cospi(n / N) for n in 0:N]),\n    )\n    for (i, (title, x)) in enumerate(cases)\n        p = fromroots(x)\n\n        # Plot p(x) over [-1,1]:\n        scatter(fig[i, 1], x, zeros(size(x)), axis=(;title))\n        lines!(fig[i, 1], -1..1, x -> p(x))\n\n        # Plot equipotential curves:\n        xx, yy = -1.3:0.02:1.3, -1:0.02:1\n        pp = [p(x + im * y) for x in xx, y in yy]\n        zz = @. log10(max(abs(pp), 1e-16))\n        ax = Axis(fig[i, 2]; title, aspect=DataAspect())\n        contour!(ax, xx, yy, zz; levels=-4:0, linewidth=2,\n            colormap=:atlantic)\n        scatter!(ax, x, zeros(size(x)); color=:black)\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p10","identifier":"p10","filename":"p10","html_id":"p10","key":"c1elMdf22q"}],"key":"p8whZWJF1s"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"This is our first contour plot.","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"VGvwIroHvP"}],"key":"GH1ezLKPEs"},{"type":"heading","depth":3,"position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Output 10","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"EgyzUAIcVp"}],"identifier":"output-10","label":"Output 10","html_id":"output-10","implicit":true,"key":"NhsNnL1Ow2"}],"key":"uZhyEU3Yk7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p10()","identifier":"output10-code","html_id":"output10-code","key":"BixfcVLVXO"},{"type":"outputs","id":"s8b7Sz7mHSyzJ0f9pREgj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":3,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"dcf1abab85df1b9c7d692c2ab2206b90","path":"tobydriscoll.net/SMiJ/build/dcf1abab85df1b9c7d692c2ab2206b90.png"},"text/html":{"content_type":"text/html","hash":"89028a10a1b8807b7ab75099e2220dad","path":"tobydriscoll.net/SMiJ/build/89028a10a1b8807b7ab75099e2220dad.html"}}},"identifier":"output10-outputs-0","html_id":"output10-outputs-0","key":"gIfbPI8pX2"}],"identifier":"output10-outputs","html_id":"output10-outputs","key":"fGTHdoK8KL"}],"label":"output10","identifier":"output10","html_id":"output10","key":"h0lL1dCZaZ"},{"type":"block","children":[{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"inlineCode","value":"fromroots","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"IyN5gtCAVa"}],"key":