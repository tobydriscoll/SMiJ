D":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter5.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter5.md","exports":[{"format":"md","filename":"chapter5.md","url":"https://tobydriscoll.net/SMiJ/build/chapter5-da7a422179b20fcc953bffc626ac1106.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 9","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"Q7yGlX1NAy"}],"identifier":"program-9","label":"Program 9","html_id":"program-9","implicit":true,"key":"lYmhnn8HU1"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p9.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, Printf, Polynomials, SpectralMethodsTrefethen\n\"p9 - polynomial interpolation in equispaced and Chebyshev pts\"\nfunction p9(N = 16)\n    xx = range(-1, 1, 801)\n    fig = Figure(size=(640, 300))\n    cases = [\n        (\"equispaced points\", [-1 + 2n / N for n in 0:N]),\n        (\"Chebyshev points\", [cospi(n / N) for n in 0:N]),\n    ]\n    f(x) = 1 / (1 + 16x^2)\n    for (i, (title, x)) in enumerate(cases)\n        v = f.(x)\n        ax = Axis(fig[1, i]; title, limits=(nothing, (-1, 1.5)))\n        scatter!(ax, x, v)\n        u = fit(Polynomial, x, v)       # interpolation\n        uu = u.(xx)                     # evaluation of interpolant\n        lines!(ax, xx, uu)\n        maxerr = @sprintf(\"%.5g\", maximum(abs, uu - f.(xx)))\n        text!(ax, 0, -0.5; text=\"max error = $maxerr\", align=(:center, :bottom))\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p9","identifier":"p9","filename":"p9","html_id":"p9","key":"cds2DHm5IK"}],"key":"TpbAf1F9JS"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"In ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"QZFsvADM8G"},{"type":"emphasis","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"abbreviation","title":"Spectral Methods in MATLAB","children":[{"type":"text","value":"SMiM","key":"ghnyyzpTla"}],"key":"mxS2wCpdqG"}],"key":"eCBAc7tTNP"},{"type":"text","value":", the notational conventions shifted a little bit for this code. Rather than using ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"fuXqNimPOG"},{"type":"inlineMath","value":"u","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>u</mi></mrow><annotation encoding=\"application/x-tex\">u</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\">u</span></span></span></span>","key":"QlTk0Kfhwh"},{"type":"text","value":" to mean a function with grid values called ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"a00aja6qbq"},{"type":"inlineMath","value":"v","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>v</mi></mrow><annotation encoding=\"application/x-tex\">v</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span cl