color=:black)\n    end\n    return fig\nend","lang":"julia","showLineNumbers":true,"label":"p10","identifier":"p10","filename":"p10","html_id":"p10","key":"yNHSsD9eLR"}],"key":"Zd1tVmekZ9"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"This is our first contour plot.","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"GUTZnKKzxk"}],"key":"IOpSLTqJwP"},{"type":"heading","depth":3,"position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Output 10","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"eyO8CI4c7O"}],"identifier":"output-10","label":"Output 10","html_id":"output-10","implicit":true,"key":"kDUdLp0qsM"}],"key":"jEjXdIYVZF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"julia","executable":true,"value":"p10()","identifier":"output10-code","html_id":"output10-code","key":"SAMiZSOcDO"},{"type":"outputs","id":"hbk4UF1pK_26imL9RETUU","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":3,"metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"dcf1abab85df1b9c7d692c2ab2206b90","path":"https://tobydriscoll.net/SMiJ/build/dcf1abab85df1b9c7d692c2ab2206b90.png"},"text/html":{"content_type":"text/html","hash":"89028a10a1b8807b7ab75099e2220dad","path":"https://tobydriscoll.net/SMiJ/build/89028a10a1b8807b7ab75099e2220dad.html"}}},"identifier":"output10-outputs-0","html_id":"output10-outputs-0","key":"c7gPyvyb0q"}],"identifier":"output10-outputs","html_id":"output10-outputs","key":"I1S6rBlIJD"}],"label":"output10","identifier":"output10","html_id":"output10","key":"uQY9tlsb9Q"},{"type":"block","children":[{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"inlineCode","value":"fromroots","position":{"start":{"line":85,"column":1},"end":{"line":85,