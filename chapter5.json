D":"singular value decomposition","EVD":"eigenvalue decomposition","SPD":"symmetric positive definite","HPD":"hermitian positive definite","PDE":"partial differential equation","ODE":"ordinary differential equation","FFT":"fast Fourier transform"},"source_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/blob/main/chapter5.md","edit_url":"https://github.com/tobydriscoll/SpectralMethodsTrefethen.jl/edit/main/chapter5.md","exports":[{"format":"md","filename":"chapter5.md","url":"tobydriscoll.net/SMiJ/build/chapter5-da7a422179b20fcc953bffc626ac1106.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Program 9","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"nSHWw04P7Y"}],"identifier":"program-9","label":"Program 9","html_id":"program-9","implicit":true,"key":"K8ptfPjh1g"},{"type":"include","file":"SpectralMethodsTrefethen/src/scripts/p9.jl","literal":true,"children":[{"type":"code","value":"using CairoMakie, Printf, Polynomials, SpectralMethodsTrefethen\n\"p9 - polynomial interpolation in equispaced and Chebyshev pts\"\nfunction p9(N = 16)\n    xx = range(-1, 1, 801)\n    fig = Figure(size=(640, 300))\n    cases = [\n        (\"equispaced points\", [-1 + 2n / N for n in 0:N]),\n        (\"Chebyshev points\", [cospi(n / N) for n in 0:N]),\n    ]\n    f(x) = 1 / (1 + 16x^2)\n    for (i, (title, x)) in enumerate(cases)\n        v = f.(x)\n        ax = Axis(fig[1, i]; title, limits=(nothing, (-1, 1.5)))\n        scatter!(ax, x, v)\n        u = fit(Polynomial, x, v)       # interpolation\n        uu = u.(xx)                     # evaluation of interpolant\n        lines!(ax, xx, uu)\n        maxerr = @sprintf(\"%.5g\", maximum(abs, uu - f.(xx)))\n        text!(ax, 0, -0.5; text=\"max error = $maxerr\", align=(:center, :bottom))\n    end\n    return fig\nend","lang":"julia","